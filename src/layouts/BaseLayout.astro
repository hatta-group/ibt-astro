---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  noindex?: boolean;
  ogType?: 'website' | 'article';
}

const {
  title,
  description = 'IB専門家庭教師IBT。IB卒業生によるマンツーマン指導でPYP・MYP・DP全科目対応。TOK・EE・IA対策も万全。入会費無料・60分無料体験実施中。',
  ogImage = '/images/og-default.jpg',
  canonical,
  noindex = false,
  ogType = 'website',
} = Astro.props;

const siteUrl = 'https://ib-tutors.net';
const fullCanonical = canonical ? `${siteUrl}${canonical}` : `${siteUrl}${Astro.url.pathname}`;
const fullOgImage = ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={fullCanonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- OGP -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={fullOgImage} />
    <meta property="og:url" content={fullCanonical} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="IBT｜IB専門家庭教師" />
    <meta property="og:locale" content="ja_JP" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={fullOgImage} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;600;700;800;900&family=Zen+Kaku+Gothic+New:wght@400;500;700&display=swap" rel="stylesheet" />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "IBT（IB Tutors）",
      "url": siteUrl,
      "description": "IB国際バカロレア専門の家庭教師サービス。IB卒業生によるマンツーマン指導。",
      "logo": {
        "@type": "ImageObject",
        "url": "https://ib-tutors.net/images/logo.png",
        "width": 512,
        "height": 512
      },
      "sameAs": [
        "https://x.com/ib_tutors_net",
        "https://www.instagram.com/ib_tutors/"
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": "IBT（IB Tutors）",
      "url": "https://ib-tutors.net",
      "description": "IB（国際バカロレア）専門の家庭教師サービス"
    })} />

    <slot name="head" />
  </head>
  <body class="font-sans text-ibt-text bg-white antialiased">
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:bg-white focus:text-ibt-red focus:font-bold focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-lg focus:outline-none">
      メインコンテンツへスキップ
    </a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />

    <!-- 固定CTAバー（スマホ・PC共通） -->
    <div class="fixed bottom-0 left-0 right-0 z-50 bg-white/95 backdrop-blur-sm border-t border-gray-200 shadow-[0_-4px_12px_rgba(0,0,0,0.1)] py-2.5 px-4">
      <div class="max-w-7xl mx-auto">
        <!-- 残り枠バッジ -->
        <div class="flex justify-center mb-1.5">
          <span class="inline-flex items-center gap-1.5 px-3 py-0.5 bg-amber-50 border border-amber-200 text-amber-800 text-xs font-bold rounded-full animate-pulse">
            <span class="w-1.5 h-1.5 bg-amber-500 rounded-full"></span>
            4月の無料体験 残り3枠
          </span>
        </div>
        <div class="flex items-center justify-center gap-3">
          <a
            href="https://line.me/R/ti/p/@974okamx"
            target="_blank"
            rel="noopener noreferrer"
            class="flex-1 max-w-[180px] inline-flex items-center justify-center gap-2 px-4 py-3 min-h-[48px] bg-[#06C755] hover:bg-[#05b34c] text-white text-sm font-bold rounded-full transition-colors"
          >
            <svg class="w-5 h-5 shrink-0" fill="currentColor" viewBox="0 0 24 24"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
            LINEで相談
          </a>
          <a
            href="/contact/"
            class="flex-1 max-w-[220px] inline-flex items-center justify-center gap-2 px-4 py-3 min-h-[48px] bg-gradient-to-r from-ibt-gradient-start to-ibt-gradient-end hover:shadow-lg text-white text-sm font-bold rounded-full transition-shadow cta-pulse"
          >
            60分無料体験を予約
          </a>
        </div>
      </div>
    </div>
    <!-- 固定CTAバー分のスペーサー（バッジ+ボタン2行分） -->
    <div class="h-24"></div>

    <!-- Cookie通知バナー -->
    <div id="cookie-banner" class="hidden fixed bottom-28 left-4 right-4 md:left-auto md:right-4 md:max-w-sm z-40 bg-white rounded-2xl shadow-xl border border-gray-200 p-5">
      <p class="text-sm text-ibt-text leading-relaxed mb-3">当サイトでは、利便性向上とアクセス解析のためにCookieを使用しています。詳しくは<a href="/privacy/" class="text-ibt-red hover:underline">プライバシーポリシー</a>をご確認ください。</p>
      <div class="flex gap-2">
        <button id="cookie-accept" class="flex-1 px-4 py-2 bg-ibt-red text-white text-sm font-bold rounded-full hover:bg-ibt-red-dark transition-colors">同意する</button>
        <button id="cookie-decline" class="px-4 py-2 bg-gray-100 text-gray-600 text-sm font-medium rounded-full hover:bg-gray-200 transition-colors">拒否</button>
      </div>
    </div>
    <script>
      if (!localStorage.getItem('cookie-consent')) {
        const banner = document.getElementById('cookie-banner');
        if (banner) banner.classList.remove('hidden');
      }
      document.getElementById('cookie-accept')?.addEventListener('click', () => {
        localStorage.setItem('cookie-consent', 'accepted');
        document.getElementById('cookie-banner')?.classList.add('hidden');
      });
      document.getElementById('cookie-decline')?.addEventListener('click', () => {
        localStorage.setItem('cookie-consent', 'declined');
        document.getElementById('cookie-banner')?.classList.add('hidden');
      });
    </script>
  </body>
</html>
