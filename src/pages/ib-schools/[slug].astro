---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const schools = await getCollection('schools');
  return schools.map((school) => ({
    params: { slug: school.data.slug },
    props: { school },
  }));
}

const { school } = Astro.props;
const { Content } = await render(school);

const programColors: Record<string, string> = {
  PYP: 'bg-emerald-100 text-emerald-700 border-emerald-200',
  MYP: 'bg-blue-100 text-blue-700 border-blue-200',
  DP: 'bg-purple-100 text-purple-700 border-purple-200',
};

const programDescriptions: Record<string, string> = {
  PYP: '初等教育（3〜12歳）',
  MYP: '中等教育（11〜16歳）',
  DP: 'ディプロマ（16〜19歳）',
};

const schoolSchema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": school.data.title,
  "description": school.data.description,
  "url": `https://ib-tutors.net/ib-schools/${school.data.slug}/`
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://ib-tutors.net/" },
    { "@type": "ListItem", "position": 2, "name": "IB認定校一覧", "item": "https://ib-tutors.net/ib-schools/" },
    { "@type": "ListItem", "position": 3, "name": school.data.title, "item": `https://ib-tutors.net/ib-schools/${school.data.slug}/` }
  ]
};
---

<BaseLayout
  title={`${school.data.title}のIB対策｜IB専門家庭教師IBT`}
  description={school.data.description}
  ogImage={school.data.ogImage}
>
  <!-- Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/85 text-sm mb-6">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/ib-schools/" class="hover:text-white transition-colors">IB認定校一覧</a>
        <span class="mx-2">/</span>
        <span class="text-white">{school.data.title}</span>
      </nav>
      <h1 class="text-2xl md:text-4xl font-bold text-white mb-4">{school.data.title}</h1>
      <div class="flex flex-wrap items-center gap-2">
        {school.data.programs.map((p: string) => (
          <span class={`px-3 py-1 rounded-full text-xs font-bold ${programColors[p] || 'bg-gray-100 text-gray-700'}`}>{p}</span>
        ))}
        <span class="px-3 py-1 rounded-full text-xs font-medium bg-white/20 text-white">{school.data.prefecture}</span>
        <span class="px-3 py-1 rounded-full text-xs font-medium bg-white/20 text-white">{school.data.schoolType}</span>
      </div>
    </div>
  </section>

  <!-- 2-Column Layout -->
  <article class="py-10 md:py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-col lg:flex-row gap-8">

        <!-- Main Content -->
        <div class="flex-1 min-w-0">
          <div class="school-content bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-10">
            <Content />
          </div>

          <!-- CTA after content (mobile-first: sidebar CTAs are below on mobile) -->
          <div class="mt-8 bg-gradient-to-br from-gray-900 to-gray-800 rounded-2xl p-8 md:p-10 text-center">
            <h2 class="text-xl md:text-2xl font-bold text-white mb-3">
              {school.data.title}のIB対策をお探しですか？
            </h2>
            <p class="text-white/70 text-sm md:text-base mb-6 leading-relaxed">
              IBTの講師は全員IB卒業生。{school.data.programs.join('・')}の全科目に対応しています。まずは60分の無料体験で、お子さまに合った学習プランをご提案します。
            </p>
            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a
                href="/contact/"
                class="inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-gradient-to-r from-ibt-gradient-start to-ibt-gradient-end text-white font-bold rounded-full hover:shadow-lg transition-shadow text-sm"
              >
                60分無料体験に申し込む
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
              </a>
              <a
                href="https://line.me/R/ti/p/@974okamx"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 px-6 py-3.5 bg-[#06C755] text-white font-bold rounded-full hover:bg-[#05b34c] transition-colors text-sm"
              >
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
                LINEで相談
              </a>
            </div>
            <p class="text-white/40 text-xs mt-4">入会金0円 / 全科目対応 / オンラインOK</p>
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:w-80 xl:w-96 shrink-0">
          <div class="lg:sticky lg:top-20 space-y-6">

            <!-- School Info Card -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
              <h3 class="font-bold text-sm text-gray-400 tracking-widest mb-4">SCHOOL INFO</h3>
              <dl class="space-y-3 text-sm">
                <div class="flex justify-between">
                  <dt class="text-gray-500">所在地</dt>
                  <dd class="font-medium text-right">{school.data.prefecture}</dd>
                </div>
                <div class="border-t border-gray-100"></div>
                <div class="flex justify-between">
                  <dt class="text-gray-500">地域</dt>
                  <dd class="font-medium text-right">{school.data.region}</dd>
                </div>
                <div class="border-t border-gray-100"></div>
                <div class="flex justify-between">
                  <dt class="text-gray-500">学校種別</dt>
                  <dd class="font-medium text-right">{school.data.schoolType}</dd>
                </div>
                <div class="border-t border-gray-100"></div>
                <div>
                  <dt class="text-gray-500 mb-2">認定プログラム</dt>
                  <dd class="flex flex-wrap gap-2">
                    {school.data.programs.map((p: string) => (
                      <span class={`inline-flex flex-col items-center px-3 py-2 rounded-xl text-xs font-bold border ${programColors[p] || 'bg-gray-100 text-gray-700 border-gray-200'}`}>
                        <span class="text-base">{p}</span>
                        <span class="text-[10px] font-normal opacity-70">{programDescriptions[p] || ''}</span>
                      </span>
                    ))}
                  </dd>
                </div>
              </dl>
            </div>

            <!-- IBT CTA Card -->
            <div class="bg-gradient-to-br from-ibt-red to-ibt-red-dark rounded-2xl p-6 text-white">
              <h3 class="font-bold text-lg mb-2">この学校のIB対策なら</h3>
              <p class="text-white/80 text-sm mb-5 leading-relaxed">
                IB卒業生講師がマンツーマンで指導。TOK・EE・IA対策もお任せください。
              </p>
              <a href="/contact/" class="block w-full text-center bg-white text-ibt-red font-bold py-3 rounded-full hover:bg-gray-50 transition-colors text-sm">
                60分無料体験に申し込む
              </a>
              <a href="https://lin.ee/xWMOBbI" class="block w-full text-center bg-white/15 text-white font-bold py-3 rounded-full hover:bg-white/25 transition-colors text-sm mt-3">
                LINEで相談する
              </a>
            </div>

            <!-- IBT Features -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
              <h3 class="font-bold text-sm text-gray-400 tracking-widest mb-4">IBTの特徴</h3>
              <ul class="space-y-4 text-sm">
                <li class="flex gap-3">
                  <div class="w-8 h-8 bg-ibt-red-50 rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-ibt-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347" /></svg>
                  </div>
                  <div>
                    <p class="font-bold">全員IB卒業生</p>
                    <p class="text-gray-500 text-xs">IBを経験した講師だから分かる</p>
                  </div>
                </li>
                <li class="flex gap-3">
                  <div class="w-8 h-8 bg-ibt-red-50 rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-ibt-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                  </div>
                  <div>
                    <p class="font-bold">入会金0円</p>
                    <p class="text-gray-500 text-xs">チケット制・長期契約なし</p>
                  </div>
                </li>
                <li class="flex gap-3">
                  <div class="w-8 h-8 bg-ibt-red-50 rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-ibt-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582" /></svg>
                  </div>
                  <div>
                    <p class="font-bold">オンライン対応</p>
                    <p class="text-gray-500 text-xs">全国どこからでも受講OK</p>
                  </div>
                </li>
              </ul>
            </div>

            <!-- Related Resources -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
              <h3 class="font-bold text-sm text-gray-400 tracking-widest mb-4">おすすめ記事</h3>
              <ul class="space-y-2.5 text-sm">
                <li><a href="/blog/ib-school-selection-guide-japan/" class="text-gray-600 hover:text-ibt-red transition-colors">IB校の選び方ガイド</a></li>
                {school.data.programs.includes('DP') && (
                  <li><a href="/blog/ib-dp-subject-selection-guide/" class="text-gray-600 hover:text-ibt-red transition-colors">DP科目選択ガイド</a></li>
                )}
                {school.data.programs.includes('MYP') && (
                  <li><a href="/blog/ib-myp-to-dp-transition-story/" class="text-gray-600 hover:text-ibt-red transition-colors">MYPからDPへの移行体験</a></li>
                )}
                <li><a href="/blog/ib-parent-honest-thoughts/" class="text-gray-600 hover:text-ibt-red transition-colors">IB生の保護者が本音で語る</a></li>
                <li><a href="/blog/ib-transfer-student-story/" class="text-gray-600 hover:text-ibt-red transition-colors">IB校に転校した体験談</a></li>
              </ul>
            </div>

            <!-- Subject Pages -->
            {school.data.programs.includes('DP') && (
              <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                <h3 class="font-bold text-sm text-gray-400 tracking-widest mb-4">科目別対策</h3>
                <div class="grid grid-cols-2 gap-2 text-xs">
                  <a href="/subjects/math-aa/" class="p-2 rounded-lg bg-gray-50 hover:bg-ibt-red-50 text-gray-600 hover:text-ibt-red transition-colors text-center font-medium">Math AA</a>
                  <a href="/subjects/english-b/" class="p-2 rounded-lg bg-gray-50 hover:bg-ibt-red-50 text-gray-600 hover:text-ibt-red transition-colors text-center font-medium">English B</a>
                  <a href="/subjects/physics/" class="p-2 rounded-lg bg-gray-50 hover:bg-ibt-red-50 text-gray-600 hover:text-ibt-red transition-colors text-center font-medium">Physics</a>
                  <a href="/subjects/chemistry/" class="p-2 rounded-lg bg-gray-50 hover:bg-ibt-red-50 text-gray-600 hover:text-ibt-red transition-colors text-center font-medium">Chemistry</a>
                  <a href="/subjects/economics/" class="p-2 rounded-lg bg-gray-50 hover:bg-ibt-red-50 text-gray-600 hover:text-ibt-red transition-colors text-center font-medium">Economics</a>
                  <a href="/subjects/tok/" class="p-2 rounded-lg bg-gray-50 hover:bg-ibt-red-50 text-gray-600 hover:text-ibt-red transition-colors text-center font-medium">TOK</a>
                </div>
                <a href="/subjects/" class="inline-flex items-center gap-1 text-ibt-red text-xs font-medium mt-3 hover:gap-2 transition-all">
                  全科目を見る
                  <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
                </a>
              </div>
            )}

            <!-- Diagnosis CTA -->
            <div class="bg-gradient-to-br from-yellow-400 to-orange-500 rounded-2xl p-6 text-white text-center">
              <h3 class="font-bold mb-2">あなたのIBerタイプは？</h3>
              <p class="text-white/80 text-sm mb-4">20問で診断できます</p>
              <a href="/iber-type-shindan/" class="block w-full bg-white text-orange-600 font-bold py-3 rounded-full hover:bg-gray-50 transition-colors text-sm">
                IBerタイプ診断を受ける
              </a>
            </div>

            <!-- Back to List -->
            <a href="/ib-schools/" class="flex items-center justify-center gap-2 w-full py-3 text-sm font-medium text-gray-500 hover:text-ibt-red bg-white rounded-2xl shadow-sm border border-gray-100 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" /></svg>
              IB認定校一覧に戻る
            </a>

          </div>
        </div>

      </div>
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(schoolSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>

<style is:global>
  .school-content h1 {
    font-size: 1.5rem;
    font-weight: 800;
    color: #111827;
    border-left: 4px solid #dc2626;
    padding-left: 1rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .school-content h2 {
    font-size: 1.25rem;
    font-weight: 800;
    color: #1f2937;
    border-left: 4px solid #dc2626;
    padding-left: 0.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.4;
  }
  .school-content h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #374151;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .school-content p {
    color: #4b5563;
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .school-content strong {
    color: #111827;
  }
  .school-content a {
    color: #dc2626;
    text-decoration: none;
    font-weight: 500;
  }
  .school-content a:hover {
    text-decoration: underline;
  }
  .school-content ul, .school-content ol {
    margin: 1rem 0;
    padding-left: 1.5rem;
    color: #4b5563;
  }
  .school-content li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }
  .school-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.875rem;
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .school-content th {
    background: #f9fafb;
    text-align: left;
    padding: 0.75rem 1rem;
    font-weight: 600;
    color: #374151;
    border-bottom: 2px solid #e5e7eb;
  }
  .school-content td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #f3f4f6;
    color: #4b5563;
  }
  .school-content tr:hover td {
    background: #f9fafb;
  }
  .school-content hr {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 2rem 0;
  }
  .school-content img {
    border-radius: 0.75rem;
    margin: 1.5rem 0;
    max-width: 100%;
    height: auto;
  }
  .school-content blockquote {
    border-left: 4px solid #e5e7eb;
    padding-left: 1rem;
    color: #6b7280;
    font-style: italic;
    margin: 1.5rem 0;
  }
  .school-content pre {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 0.75rem;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin: 1rem 0;
    white-space: pre-wrap;
    word-wrap: break-word;
  }
  .school-content code {
    background: #f3f4f6;
    padding: 0.15rem 0.4rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    color: #374151;
  }
  .school-content pre code {
    background: none;
    padding: 0;
    font-size: 0.875rem;
    color: #374151;
  }
</style>
