---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const schools = await getCollection('schools');
  return schools.map((school) => ({
    params: { slug: school.data.slug },
    props: { school },
  }));
}

const { school } = Astro.props;
const { Content } = await render(school);

const schoolSchema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": school.data.title,
  "description": school.data.description,
  "url": `https://ib-tutors.net/ib-schools/${school.data.slug}/`
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "ホーム",
      "item": "https://ib-tutors.net/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "IB認定校一覧",
      "item": "https://ib-tutors.net/ib-schools/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": school.data.title,
      "item": `https://ib-tutors.net/ib-schools/${school.data.slug}/`
    }
  ]
};
---

<BaseLayout
  title={`${school.data.title}｜IB認定校｜IBT`}
  description={school.data.description}
  ogImage={school.data.ogImage}
>
  <!-- Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/70 text-sm mb-6">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/ib-schools/" class="hover:text-white transition-colors">IB認定校一覧</a>
        <span class="mx-2">/</span>
        <span class="text-white">{school.data.title}</span>
      </nav>
      <h1 class="text-2xl md:text-4xl font-bold text-white">{school.data.title}</h1>
    </div>
  </section>

  <!-- Content -->
  <article class="py-12 md:py-20 bg-white">
    <div class="max-w-3xl mx-auto px-4 prose prose-lg
      prose-headings:font-black prose-headings:text-gray-900
      prose-h1:text-2xl prose-h1:md:text-3xl prose-h1:border-b-2 prose-h1:border-red-600 prose-h1:pb-3 prose-h1:mb-6
      prose-h2:text-xl prose-h2:md:text-2xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:text-gray-800
      prose-h3:text-lg prose-h3:text-gray-700
      prose-p:text-gray-600 prose-p:leading-relaxed
      prose-a:text-red-600 prose-a:no-underline hover:prose-a:underline
      prose-strong:text-gray-900
      prose-table:text-sm
      prose-th:bg-gray-50 prose-th:text-left prose-th:px-4 prose-th:py-3
      prose-td:px-4 prose-td:py-3 prose-td:border-b prose-td:border-gray-100
      prose-li:text-gray-600
      prose-img:rounded-xl">
      <Content />
    </div>
  </article>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-ibt-bg">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">この学校のIB対策をお探しですか？</h2>
      <p class="text-ibt-text-light text-lg mb-8">
        IB卒業生の専門家庭教師がマンツーマンでサポートします。まずは60分の無料体験をお試しください。
      </p>
      <a
        href="/contact/"
        class="inline-block px-8 py-4 bg-ibt-red text-white font-bold rounded-full shadow-lg hover:bg-ibt-red-dark transition-colors cta-pulse"
      >
        60分無料体験に申し込む
      </a>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schoolSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>
