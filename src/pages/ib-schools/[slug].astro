---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const schools = await getCollection('schools');
  return schools.map((school) => ({
    params: { slug: school.data.slug },
    props: { school },
  }));
}

const { school } = Astro.props;
const { Content } = await render(school);

const programColors: Record<string, string> = {
  PYP: 'bg-emerald-100 text-emerald-700',
  MYP: 'bg-blue-100 text-blue-700',
  DP: 'bg-purple-100 text-purple-700',
};

const schoolSchema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": school.data.title,
  "description": school.data.description,
  "url": `https://ib-tutors.net/ib-schools/${school.data.slug}/`
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://ib-tutors.net/" },
    { "@type": "ListItem", "position": 2, "name": "IB認定校一覧", "item": "https://ib-tutors.net/ib-schools/" },
    { "@type": "ListItem", "position": 3, "name": school.data.title, "item": `https://ib-tutors.net/ib-schools/${school.data.slug}/` }
  ]
};
---

<BaseLayout
  title={`${school.data.title}のIB対策｜IB専門家庭教師IBT`}
  description={school.data.description}
  ogImage={school.data.ogImage}
>
  <!-- Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/70 text-sm mb-6">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/ib-schools/" class="hover:text-white transition-colors">IB認定校一覧</a>
        <span class="mx-2">/</span>
        <span class="text-white">{school.data.title}</span>
      </nav>
      <h1 class="text-2xl md:text-4xl font-bold text-white mb-4">{school.data.title}</h1>
      <div class="flex flex-wrap items-center gap-2">
        {school.data.programs.map((p: string) => (
          <span class={`px-3 py-1 rounded-full text-xs font-bold ${programColors[p] || 'bg-gray-100 text-gray-700'}`}>{p}</span>
        ))}
        <span class="px-3 py-1 rounded-full text-xs font-medium bg-white/20 text-white">{school.data.prefecture}</span>
        <span class="px-3 py-1 rounded-full text-xs font-medium bg-white/20 text-white">{school.data.schoolType}</span>
      </div>
    </div>
  </section>

  <!-- Quick Info Bar -->
  <div class="bg-white border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 py-4 flex flex-wrap gap-6 text-sm text-gray-600">
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /></svg>
        <span>{school.data.prefecture} / {school.data.region}</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" /></svg>
        <span>{school.data.schoolType}</span>
      </div>
      <div class="flex items-center gap-2">
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
        <span>{school.data.programs.join(' / ')}</span>
      </div>
    </div>
  </div>

  <!-- Content -->
  <article class="py-12 md:py-20 bg-gray-50">
    <div class="max-w-3xl mx-auto px-4">
      <div class="school-content bg-white rounded-2xl shadow-sm border border-gray-100 p-8 md:p-12">
        <Content />
      </div>
    </div>
  </article>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">この学校のIB対策をお探しですか？</h2>
      <p class="text-gray-500 text-lg mb-8">
        IB卒業生の専門家庭教師がマンツーマンでサポートします。まずは60分の無料体験をお試しください。
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contact/" class="inline-block px-8 py-4 bg-ibt-red text-white font-bold rounded-full shadow-lg hover:bg-ibt-red-dark transition-colors">
          60分無料体験に申し込む
        </a>
        <a href="https://lin.ee/xWMOBbI" class="inline-flex items-center justify-center px-8 py-4 bg-[#06C755] text-white font-bold rounded-full shadow-lg hover:bg-[#05b04c] transition-colors">
          LINEで相談する
        </a>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify(schoolSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>

<style is:global>
  .school-content h1 {
    font-size: 1.5rem;
    font-weight: 800;
    color: #111827;
    border-left: 4px solid #dc2626;
    padding-left: 1rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }
  .school-content h2 {
    font-size: 1.25rem;
    font-weight: 800;
    color: #1f2937;
    border-left: 4px solid #dc2626;
    padding-left: 0.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.4;
  }
  .school-content h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #374151;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .school-content p {
    color: #4b5563;
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .school-content strong {
    color: #111827;
  }
  .school-content a {
    color: #dc2626;
    text-decoration: none;
    font-weight: 500;
  }
  .school-content a:hover {
    text-decoration: underline;
  }
  .school-content ul, .school-content ol {
    margin: 1rem 0;
    padding-left: 1.5rem;
    color: #4b5563;
  }
  .school-content li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }
  .school-content table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.5rem 0;
    font-size: 0.9rem;
  }
  .school-content th {
    background: #f9fafb;
    text-align: left;
    padding: 0.75rem 1rem;
    font-weight: 600;
    color: #374151;
    border-bottom: 2px solid #e5e7eb;
  }
  .school-content td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid #f3f4f6;
    color: #4b5563;
  }
  .school-content tr:hover td {
    background: #f9fafb;
  }
  .school-content hr {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 2rem 0;
  }
  .school-content img {
    border-radius: 0.75rem;
    margin: 1.5rem 0;
  }
  .school-content blockquote {
    border-left: 4px solid #e5e7eb;
    padding-left: 1rem;
    color: #6b7280;
    font-style: italic;
    margin: 1.5rem 0;
  }
</style>
