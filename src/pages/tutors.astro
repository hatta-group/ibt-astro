---
import BaseLayout from '../layouts/BaseLayout.astro';
import { tutors } from '../data/tutors';
---

<BaseLayout
  title="講師紹介｜IB専門家庭教師IBT"
  description="IBT講師は全員IB卒業生。TOK・EE・IA対策の経験を活かした専門指導。日英バイリンガル対応。まず無料体験でご確認ください。"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://ib-tutors.net/" },
        { "@type": "ListItem", "position": 2, "name": "講師紹介", "item": "https://ib-tutors.net/tutors/" }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify(
      tutors.map(tutor => ({
        "@context": "https://schema.org",
        "@type": "Person",
        "name": tutor.fullName || tutor.name,
        ...(tutor.image ? { "image": `https://ib-tutors.net${tutor.image}` } : {}),
        "jobTitle": "IB専門家庭教師",
        "affiliation": {"@type": "Organization", "name": "IBT（IB Tutors）", "url": "https://ib-tutors.net"},
        "knowsAbout": tutor.subjects,
        "alumniOf": tutor.university
      }))
    )} />
  </Fragment>

  <!-- Page Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/70 text-sm mb-4">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">&gt;</span>
        <span class="text-white">講師紹介</span>
      </nav>
      <h1 class="text-3xl md:text-5xl font-bold text-white">講師紹介</h1>
      <p class="text-white/80 mt-3 text-lg">IBT講師は全員IB卒業生。45点満点講師も在籍。</p>
    </div>
  </section>

  <!-- Tutor Grid -->
  <section class="py-16 md:py-24 bg-ibt-bg">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12 md:mb-16">
        <p class="text-ibt-red font-bold text-sm tracking-widest mb-4">OUR TUTORS</p>
        <h2 class="text-2xl md:text-4xl font-bold">IBT講師一覧</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {tutors.map((tutor) => {
          const initials = tutor.name.slice(0, 2);
          return (
            <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8 hover:shadow-md transition-shadow">
              <div class="flex items-start gap-5">
                {tutor.image ? (
                  <img src={tutor.image} alt={`${tutor.name}講師`} class="w-16 h-16 rounded-full object-cover shrink-0" loading="lazy" width="64" height="64" />
                ) : (
                  <div class="w-16 h-16 bg-gradient-to-br from-ibt-gradient-start to-ibt-gradient-end rounded-full flex items-center justify-center shrink-0">
                    <span class="text-white font-bold text-lg">{initials}</span>
                  </div>
                )}
                <div class="min-w-0">
                  <h3 class="text-xl font-bold">{tutor.name}</h3>
                  <p class="text-ibt-text-light text-sm mt-1">
                    <span class="inline-block mr-1">
                      <svg class="w-3.5 h-3.5 inline -mt-0.5 text-ibt-text-light/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
                      </svg>
                    </span>
                    {tutor.school}
                  </p>
                  <p class="text-ibt-text-light text-sm">
                    <span class="inline-block mr-1">
                      <svg class="w-3.5 h-3.5 inline -mt-0.5 text-ibt-text-light/60" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3H21m-3.75 3H21" />
                      </svg>
                    </span>
                    {tutor.university}
                  </p>
                </div>
              </div>
              <!-- Subject tags -->
              <div class="flex flex-wrap gap-2 mt-5">
                {tutor.subjects.map((subject) => (
                  <span class="bg-ibt-red-50 text-ibt-red text-xs font-medium px-3 py-1.5 rounded-full">
                    {subject}
                  </span>
                ))}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- 講師の特徴 -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12 md:mb-16">
        <p class="text-ibt-red font-bold text-sm tracking-widest mb-4">WHY IBT TUTORS</p>
        <h2 class="text-2xl md:text-4xl font-bold">IBT講師の特徴</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 max-w-4xl mx-auto">
        <!-- Feature 1 -->
        <div class="flex gap-5 items-start bg-ibt-bg rounded-2xl p-6 md:p-8">
          <div class="w-12 h-12 bg-ibt-red-50 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-ibt-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.745 3.745 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-2">全員がIBプログラムを修了</h3>
            <p class="text-ibt-text-light leading-relaxed text-sm">IBの厳しいカリキュラムを自ら経験した講師だからこそ、生徒の悩みや壁を理解し、的確なアドバイスができます。</p>
          </div>
        </div>

        <!-- Feature 2 -->
        <div class="flex gap-5 items-start bg-ibt-bg rounded-2xl p-6 md:p-8">
          <div class="w-12 h-12 bg-ibt-red-50 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-ibt-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5Z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-2">45点満点取得者を含む優秀な講師陣</h3>
            <p class="text-ibt-text-light leading-relaxed text-sm">IBディプロマで最高得点の45点を取得した講師も在籍。高得点を目指す生徒に実践的な学習戦略を伝えます。</p>
          </div>
        </div>

        <!-- Feature 3 -->
        <div class="flex gap-5 items-start bg-ibt-bg rounded-2xl p-6 md:p-8">
          <div class="w-12 h-12 bg-ibt-red-50 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-ibt-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-2">日本語・英語のバイリンガル対応</h3>
            <p class="text-ibt-text-light leading-relaxed text-sm">日本語でも英語でも授業を受けられます。英語での学習に不安がある生徒も、日本語でサポートするので安心です。</p>
          </div>
        </div>

        <!-- Feature 4 -->
        <div class="flex gap-5 items-start bg-ibt-bg rounded-2xl p-6 md:p-8">
          <div class="w-12 h-12 bg-ibt-red-50 rounded-xl flex items-center justify-center shrink-0">
            <svg class="w-6 h-6 text-ibt-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
            </svg>
          </div>
          <div>
            <h3 class="font-bold text-lg mb-2">生徒の「先輩」として親身にサポート</h3>
            <p class="text-ibt-text-light leading-relaxed text-sm">年齢が近い「先輩」だからこそ、気軽に相談できる関係を構築。勉強だけでなく、IB生活全般のアドバイスも行います。</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-ibt-bg">
    <div class="max-w-7xl mx-auto px-4">
      <div class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end rounded-2xl p-10 md:p-16 text-center">
        <h2 class="text-2xl md:text-4xl font-bold text-white mb-4">講師と無料体験してみませんか？</h2>
        <p class="text-white/80 mb-8 text-lg max-w-xl mx-auto">
          60分の無料体験で、IB卒業生講師の指導を実感してください。お子さまに合った講師をご紹介します。
        </p>
        <a
          href="/contact/"
          class="inline-block bg-white text-ibt-red font-bold px-8 py-4 rounded-full hover:bg-ibt-red-light transition-colors text-lg shadow-lg"
        >
          無料体験を申し込む
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
