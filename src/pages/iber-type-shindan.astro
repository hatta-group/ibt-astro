      },
    };

    function showResult() {
      quizContainer.classList.add('hidden');
      resultContainer.classList.remove('hidden');

      // Calculate total and find winner
      let maxScore = 0;
      let winnerId = 'inquirer';
      let totalScore = 0;
      for (const [id, score] of Object.entries(scores)) {
        totalScore += score;
        if (score > maxScore) {
          maxScore = score;
          winnerId = id;
        }
      }

      const winner = types.find((t) => t.id === winnerId);
      const details = typeDetails[winnerId];

      // Header color
      const header = document.getElementById('result-header');
      header.style.background = `linear-gradient(135deg, ${winner.color}ee, ${winner.color}99)`;

      // Type image
      const img = document.getElementById('result-image');
      img.src = `/images/iber-types/${winner.id}.png`;
      img.alt = `${winner.name} - ${winner.nameJa}`;

      // Badge
      const badge = document.getElementById('result-badge');
      badge.textContent = winner.name;

      // Name & description
      document.getElementById('result-name-ja').textContent = winner.nameJa;
      document.getElementById('result-desc').textContent = winner.description;
      document.getElementById('result-link').href = `/iber-type/${winner.id}/`;

      // Strengths
      const strengthsList = document.getElementById('result-strengths');
      strengthsList.innerHTML = '';
      details.strengths.forEach((s) => {
        const li = document.createElement('li');
        li.className = 'flex items-start gap-2';
        li.innerHTML = `<svg class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg><span>${s}</span>`;
        strengthsList.appendChild(li);
      });

      // Challenges
      const challengesList = document.getElementById('result-challenges');
      challengesList.innerHTML = '';
      details.challenges.forEach((c) => {
        const li = document.createElement('li');
        li.className = 'flex items-start gap-2';
        li.innerHTML = `<svg class="w-4 h-4 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg><span>${c}</span>`;
        challengesList.appendChild(li);
      });

      // Score distribution bars
      const scoresContainer = document.getElementById('result-scores');
      scoresContainer.innerHTML = '';
      // Sort types by score descending
      const sortedTypes = [...types].sort((a, b) => (scores[b.id] || 0) - (scores[a.id] || 0));
      sortedTypes.forEach((t) => {
        const score = scores[t.id] || 0;
        const pct = totalScore > 0 ? Math.round((score / totalScore) * 100) : 0;
        const isWinner = t.id === winnerId;
        const row = document.createElement('div');
        row.className = 'flex items-center gap-3';
        row.innerHTML = `
          <div class="w-28 md:w-36 text-right shrink-0">
            <span class="text-xs font-bold ${isWinner ? 'text-ibt-text' : 'text-ibt-text-light'}">${t.name}</span>
          </div>
          <div class="flex-1 bg-ibt-border rounded-full h-5 overflow-hidden">
            <div class="h-full rounded-full transition-all duration-700 ease-out" style="width: ${pct}%; background-color: ${t.color}; ${isWinner ? 'box-shadow: 0 0 8px ' + t.color + '60;' : 'opacity: 0.6;'}"></div>
          </div>
          <span class="w-10 text-xs font-bold text-right ${isWinner ? 'text-ibt-text' : 'text-ibt-text-light'}">${pct}%</span>
        `;
        scoresContainer.appendChild(row);
      });

      // Analysis text
      document.getElementById('result-analysis-text').textContent = details.analysis;

      // Share buttons
      const shareText = `IBerタイプ診断の結果、私は「${winner.name}（${winner.nameJa}）」でした！あなたも診断してみよう！`;
      const shareUrl = 'https://ib-tutors.net/iber-type-shindan/';

      document.getElementById('share-x').onclick = () => {
        window.open(
          `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`,
          '_blank'
        );
      };
      document.getElementById('share-line').onclick = () => {
        window.open(
          `https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(shareUrl)}&text=${encodeURIComponent(shareText)}`,
          '_blank'
        );
      };

      resultContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function resetQuiz() {
      currentQuestion = 0;
      types.forEach((t) => (scores[t.id] = 0));
      resultContainer.classList.add('hidden');
      startScreen.classList.remove('hidden');
      quizContainer.classList.add('hidden');
      startScreen.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    startBtn.addEventListener('click', () => {
      startScreen.classList.add('hidden');
      quizContainer.classList.remove('hidden');
      renderQuestion();
    });

    retryBtn.addEventListener('click', resetQuiz);
  </script>
</BaseLayout>
