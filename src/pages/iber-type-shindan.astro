    function showResult(directTypeId) {
      quizContainer.classList.add('hidden');
      startScreen.classList.add('hidden');
      resultContainer.classList.remove('hidden');

      let winnerId;
      let totalScore = 0;

      if (directTypeId) {
        // Direct link access - use provided type ID
        winnerId = directTypeId;
        isDirectResult = true;
        // Hide score distribution for direct link results
        document.getElementById('score-distribution-section').classList.add('hidden');
        // Show "try it yourself" CTA
        document.getElementById('direct-link-cta').classList.remove('hidden');
      } else {
        // Normal quiz completion - calculate winner
        let maxScore = 0;
        winnerId = 'inquirer';
        for (const [id, score] of Object.entries(scores)) {
          totalScore += score;
          if (score > maxScore) {
            maxScore = score;
            winnerId = id;
          }
        }
        // Update URL with result parameter
        history.replaceState(null, '', '?result=' + winnerId);
      }

      const winner = types.find((t) => t.id === winnerId);
      if (!winner) return;
      const details = typeDetails[winnerId];
      if (!details) return;

      // Header color
      const header = document.getElementById('result-header');
      header.style.background = `linear-gradient(135deg, ${winner.color}ee, ${winner.color}99)`;

      // Type image
      const img = document.getElementById('result-image');
      img.src = `/images/iber-types/${winner.id}.png`;
      img.alt = `${winner.name} - ${winner.nameJa}`;

      // Badge
      const badge = document.getElementById('result-badge');
      badge.textContent = winner.name;

      // Name & description
      document.getElementById('result-name-ja').textContent = winner.nameJa;
      document.getElementById('result-desc').textContent = winner.description;
      document.getElementById('result-link').href = `/iber-type/${winner.id}/`;

      // Statistics
      const statEl = document.getElementById('result-stat');
      const statPct = typeStats[winnerId] || 10;
      statEl.textContent = '全診断者の約' + statPct + '%がこのタイプ';

      // Strengths
      const strengthsList = document.getElementById('result-strengths');
      strengthsList.innerHTML = '';
      details.strengths.forEach((s) => {
        const li = document.createElement('li');
        li.className = 'flex items-start gap-2';
        li.innerHTML = `<svg class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/></svg><span>${s}</span>`;
        strengthsList.appendChild(li);
      });

      // Challenges
      const challengesList = document.getElementById('result-challenges');
      challengesList.innerHTML = '';
      details.challenges.forEach((c) => {
        const li = document.createElement('li');
        li.className = 'flex items-start gap-2';
        li.innerHTML = `<svg class="w-4 h-4 text-amber-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z"/></svg><span>${c}</span>`;
        challengesList.appendChild(li);
      });

      // Score distribution bars (only for quiz completions, not direct links)
      if (!directTypeId) {
        const scoresContainer = document.getElementById('result-scores');
        scoresContainer.innerHTML = '';
        const sortedTypes = [...types].sort((a, b) => (scores[b.id] || 0) - (scores[a.id] || 0));
        sortedTypes.forEach((t) => {
          const score = scores[t.id] || 0;
          const pct = totalScore > 0 ? Math.round((score / totalScore) * 100) : 0;
          const isWinner = t.id === winnerId;
          const row = document.createElement('div');
          row.className = 'flex items-center gap-3';
          row.innerHTML = `
            <div class="w-28 md:w-36 text-right shrink-0">
              <span class="text-xs font-bold ${isWinner ? 'text-ibt-text' : 'text-ibt-text-light'}">${t.name}</span>
            </div>
            <div class="flex-1 bg-ibt-border rounded-full h-5 overflow-hidden">
              <div class="h-full rounded-full transition-all duration-700 ease-out" style="width: ${pct}%; background-color: ${t.color}; ${isWinner ? 'box-shadow: 0 0 8px ' + t.color + '60;' : 'opacity: 0.6;'}"></div>
            </div>
            <span class="w-10 text-xs font-bold text-right ${isWinner ? 'text-ibt-text' : 'text-ibt-text-light'}">${pct}%</span>
          `;
          scoresContainer.appendChild(row);
        });
      }

      // Analysis text
      document.getElementById('result-analysis-text').textContent = details.analysis;

      // Get analysis div to insert new sections after it
      var analysisDiv = document.getElementById('result-analysis');

      // Add personality summary
      var personalityDiv = document.createElement('div');
      personalityDiv.className = 'bg-white rounded-2xl shadow-sm border border-ibt-border p-6 md:p-8 mb-8';
      personalityDiv.innerHTML = '<div class="flex items-center gap-3 mb-4"><div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background-color:' + winner.color + '20"><svg class="w-5 h-5" style="color:' + winner.color + '" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0"/></svg></div><h3 class="font-bold text-lg">あなたの性格</h3></div><p class="text-ibt-text-light leading-relaxed">' + details.personality + '</p>';
      analysisDiv.parentNode.insertBefore(personalityDiv, analysisDiv.nextSibling);

      // Add study style
      var studyDiv = document.createElement('div');
      studyDiv.className = 'bg-white rounded-2xl shadow-sm border border-ibt-border p-6 md:p-8 mb-8';
      studyDiv.innerHTML = '<div class="flex items-center gap-3 mb-4"><div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background-color:' + winner.color + '20"><svg class="w-5 h-5" style="color:' + winner.color + '" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/></svg></div><h3 class="font-bold text-lg">あなたの勉強スタイル</h3></div><p class="text-ibt-text-light leading-relaxed">' + details.studyStyle + '</p>';
      personalityDiv.parentNode.insertBefore(studyDiv, personalityDiv.nextSibling);

      // Add best subjects
      var subjectsDiv = document.createElement('div');
      subjectsDiv.className = 'bg-white rounded-2xl shadow-sm border border-ibt-border p-6 md:p-8 mb-8';
      var subjectsHtml = '<div class="flex items-center gap-3 mb-4"><div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background-color:' + winner.color + '20"><svg class="w-5 h-5" style="color:' + winner.color + '" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347"/></svg></div><h3 class="font-bold text-lg">得意になりやすい科目</h3></div><div class="flex flex-wrap gap-2">';
      details.bestSubjects.forEach(function(s) { subjectsHtml += '<span class="px-4 py-2 rounded-full text-sm font-bold" style="background-color:' + winner.color + '15;color:' + winner.color + '">' + s + '</span>'; });
      subjectsHtml += '</div>';
      subjectsDiv.innerHTML = subjectsHtml;
      studyDiv.parentNode.insertBefore(subjectsDiv, studyDiv.nextSibling);

      // Add compatible types
      var compatDiv = document.createElement('div');
      compatDiv.className = 'bg-white rounded-2xl shadow-sm border border-ibt-border p-6 md:p-8 mb-8';
      compatDiv.innerHTML = '<div class="flex items-center gap-3 mb-4"><div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background-color:' + winner.color + '20"><svg class="w-5 h-5" style="color:' + winner.color + '" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/></svg></div><h3 class="font-bold text-lg">相性の良いタイプ</h3></div><p class="text-ibt-text-light">' + details.compatibleTypes.join('、') + ' と相性が良いです。一緒にグループワークをすると互いの強みを引き出せます。</p>';
      subjectsDiv.parentNode.insertBefore(compatDiv, subjectsDiv.nextSibling);

      // Add growth tip
      var tipDiv = document.createElement('div');
      tipDiv.className = 'rounded-2xl p-6 md:p-8 mb-8 text-white';
      tipDiv.style.background = 'linear-gradient(135deg, ' + winner.color + ', ' + winner.color + 'cc)';
      tipDiv.innerHTML = '<h3 class="font-bold text-lg mb-3">成長のヒント</h3><p class="text-white/90 leading-relaxed">' + details.growthTip + '</p>';
      compatDiv.parentNode.insertBefore(tipDiv, compatDiv.nextSibling);

      // Share buttons - include result parameter in share URL
      const shareText = `IBerタイプ診断の結果、私は「${winner.name}（${winner.nameJa}）」でした!あなたも診断してみよう!`;
      const shareUrl = 'https://ib-tutors.net/iber-type-shindan/?result=' + winnerId;

      document.getElementById('share-x').onclick = () => {
        window.open(
          `https://twitter.com/intent/tweet?text=${encodeURIComponent(shareText)}&url=${encodeURIComponent(shareUrl)}`,
          '_blank'
        );
      };
      document.getElementById('share-line').onclick = () => {
        window.open(
          `https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(shareUrl)}&text=${encodeURIComponent(shareText)}`,
          '_blank'
        );
      };

      // Instagram share - show image and download
      const igShareImage = `/images/iber-types/share/${winnerId}.png`;
      const igPreview = document.getElementById('ig-share-preview');
      const igImage = document.getElementById('ig-share-image');
      const igDownloadBtn = document.getElementById('ig-download-btn');
      igImage.src = igShareImage;
      igImage.alt = `IBerタイプ診断結果: ${winner.name}（${winner.nameJa}）`;
      igDownloadBtn.href = igShareImage;
      igDownloadBtn.download = `IBerタイプ診断_${winner.name}.png`;

      document.getElementById('share-ig').onclick = () => {
        igPreview.classList.toggle('hidden');
        if (!igPreview.classList.contains('hidden')) {
          igPreview.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
      };

      resultContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function resetQuiz() {
      currentQuestion = 0;
      types.forEach((t) => (scores[t.id] = 0));
      answerHistory.length = 0;
      isDirectResult = false;
      // Remove dynamically added sections
      var dynamicSections = resultContainer.querySelectorAll('.bg-white.rounded-2xl.shadow-sm.border.border-ibt-border.p-6.md\\:p-8.mb-8:not(#result-analysis):not(#score-distribution-section):not(.grid *)');
      // Remove personality, study, subjects, compat, tip divs that were dynamically added
      var analysisDiv = document.getElementById('result-analysis');
      if (analysisDiv) {
        var next = analysisDiv.nextElementSibling;
        while (next && next.id !== 'score-distribution-section' && !next.classList.contains('grid') && next.id !== 'direct-link-cta' && !next.classList.contains('flex')) {
          var toRemove = next;
          next = next.nextElementSibling;
          toRemove.remove();
        }
      }
      resultContainer.classList.add('hidden');
      startScreen.classList.remove('hidden');
      quizContainer.classList.add('hidden');
      // Show score distribution section again
      document.getElementById('score-distribution-section').classList.remove('hidden');
      // Hide direct link CTA
      document.getElementById('direct-link-cta').classList.add('hidden');
      // Reset URL
      history.replaceState(null, '', window.location.pathname);
      startScreen.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // Check for URL parameter on page load
    const urlParams = new URLSearchParams(window.location.search);
    const resultParam = urlParams.get('result');
    if (resultParam && typeDetails[resultParam]) {
      // Direct link - show result immediately
      showResult(resultParam);
    }

    // Back button
    document.getElementById('back-btn').addEventListener('click', () => {
      if (currentQuestion > 0 && answerHistory.length > 0) {
        const lastTypes = answerHistory.pop();
        lastTypes.forEach((id) => (scores[id] = Math.max(0, (scores[id] || 0) - 1)));
        currentQuestion--;
        renderQuestion();
      }
    });

    startBtn.addEventListener('click', () => {
      startScreen.classList.add('hidden');
      quizContainer.classList.remove('hidden');
      renderQuestion();
    });

    // Direct start button (shown in direct link results)
    const directStartBtn = document.getElementById('direct-start-btn');
    if (directStartBtn) {
      directStartBtn.addEventListener('click', () => {
        resetQuiz();
        startScreen.classList.add('hidden');
        quizContainer.classList.remove('hidden');
        renderQuestion();
      });
    }

    retryBtn.addEventListener('click', resetQuiz);
  </script>

  <style>
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }
    .shindan-characters > div:nth-child(even) {
      margin-top: 12px;
    }
  </style>
</BaseLayout>
