---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="マイアカウント｜IB専門家庭教師IBT"
  description="IBTチケット管理ダッシュボード。チケット残数の確認、予約状況の閲覧ができます。"
  noindex={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://ib-tutors.net/" },
        { "@type": "ListItem", "position": 2, "name": "マイアカウント", "item": "https://ib-tutors.net/my-account/" }
      ]
    })} />
  </Fragment>

  <!-- Page Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/85 text-sm mb-4">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">&gt;</span>
        <span class="text-white">マイアカウント</span>
      </nav>
      <h1 class="text-3xl md:text-5xl font-bold text-white">マイアカウント</h1>
      <p class="text-white/80 mt-3 text-lg">チケット残数・予約状況を確認できます</p>
    </div>
  </section>

  <!-- Password Gate -->
  <section id="password-gate" class="py-24 md:py-32 bg-ibt-bg">
    <div class="max-w-md mx-auto px-4 text-center">
      <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8 md:p-10">
        <div class="w-16 h-16 bg-ibt-red-50 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8 text-ibt-red" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z" />
          </svg>
        </div>
        <h2 class="text-xl font-bold text-ibt-text mb-2">パスワードを入力してください</h2>
        <p class="text-ibt-text-light text-sm mb-6">このページは生徒様・講師専用です。<br>ご案内済みのパスワードを入力してください。</p>
        <form id="password-form" class="space-y-4">
          <input
            type="password"
            id="password-input"
            placeholder="パスワード"
            autocomplete="off"
            class="w-full px-4 py-3 border border-ibt-border rounded-xl text-center text-lg tracking-widest focus:outline-none focus:ring-2 focus:ring-ibt-red/30 focus:border-ibt-red transition-colors"
          />
          <p id="password-error" class="text-red-500 text-sm hidden">パスワードが正しくありません</p>
          <button
            type="submit"
            class="w-full bg-gradient-to-r from-ibt-gradient-start to-ibt-gradient-end text-white font-bold px-6 py-3 rounded-full hover:shadow-lg transition-shadow"
          >
            ログイン
          </button>
        </form>
      </div>
    </div>
  </section>

  <!-- Main Content (hidden by default) -->
  <div id="main-content" class="hidden">

    <!-- Role Selector -->
    <section id="role-selector" class="py-16 md:py-20 bg-ibt-bg">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <p class="text-ibt-red font-bold text-sm tracking-widest mb-4">SELECT ROLE</p>
        <h2 class="text-2xl md:text-4xl font-bold text-ibt-text mb-8">ログイン種別を選んでください</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <button data-role="parent" class="role-btn group bg-white rounded-2xl shadow-sm border-2 border-ibt-border hover:border-ibt-red p-8 transition-all">
            <div class="w-16 h-16 bg-blue-50 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-blue-100 transition-colors">
              <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
              </svg>
            </div>
            <p class="font-bold text-ibt-text text-lg">保護者</p>
            <p class="text-ibt-text-light text-sm mt-1">チケット残数・予約確認</p>
          </button>
          <button data-role="teacher" class="role-btn group bg-white rounded-2xl shadow-sm border-2 border-ibt-border hover:border-ibt-red p-8 transition-all">
            <div class="w-16 h-16 bg-green-50 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-green-100 transition-colors">
              <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342M6.75 15a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm0 0v-3.675A55.378 55.378 0 0 1 12 8.443m-7.007 11.55A5.981 5.981 0 0 0 6.75 15.75v-1.5" />
              </svg>
            </div>
            <p class="font-bold text-ibt-text text-lg">講師</p>
            <p class="text-ibt-text-light text-sm mt-1">スケジュール・生徒情報</p>
          </button>
          <button data-role="admin" class="role-btn group bg-white rounded-2xl shadow-sm border-2 border-ibt-border hover:border-ibt-red p-8 transition-all">
            <div class="w-16 h-16 bg-purple-50 rounded-full flex items-center justify-center mx-auto mb-4 group-hover:bg-purple-100 transition-colors">
              <svg class="w-8 h-8 text-purple-600" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
              </svg>
            </div>
            <p class="font-bold text-ibt-text text-lg">管理者</p>
            <p class="text-ibt-text-light text-sm mt-1">全体管理・統計</p>
          </button>
        </div>
      </div>
    </section>

    <!-- ===== PARENT VIEW ===== -->
    <section id="view-parent" class="hidden py-12 md:py-16 bg-ibt-bg">
      <div class="max-w-5xl mx-auto px-4">

        <!-- Back & Title -->
        <div class="flex items-center gap-4 mb-8">
          <button class="back-to-role text-ibt-text-light hover:text-ibt-red transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
          </button>
          <div>
            <p class="text-ibt-red font-bold text-sm tracking-widest">PARENT DASHBOARD</p>
            <h2 class="text-2xl md:text-3xl font-bold text-ibt-text">保護者ダッシュボード</h2>
          </div>
        </div>

        <!-- Email Lookup -->
        <div id="parent-email-gate" class="bg-white rounded-2xl shadow-sm border border-ibt-border p-6 md:p-8 mb-8">
          <h3 class="font-bold text-ibt-text text-lg mb-4">メールアドレスで検索</h3>
          <p class="text-ibt-text-light text-sm mb-4">ご登録のメールアドレスを入力してください。</p>
          <form id="parent-email-form" class="flex flex-col sm:flex-row gap-3">
            <input
              type="email"
              id="parent-email-input"
              placeholder="example@email.com"
              class="flex-1 px-4 py-3 border border-ibt-border rounded-xl focus:outline-none focus:ring-2 focus:ring-ibt-red/30 focus:border-ibt-red transition-colors"
            />
            <button type="submit" class="px-6 py-3 bg-gradient-to-r from-ibt-gradient-start to-ibt-gradient-end text-white font-bold rounded-full hover:shadow-lg transition-shadow whitespace-nowrap">
              検索
            </button>
          </form>
          <p id="parent-email-error" class="text-red-500 text-sm mt-2 hidden">該当するアカウントが見つかりませんでした。</p>
        </div>

        <!-- Parent Dashboard Content (hidden until email entered) -->
        <div id="parent-dashboard" class="hidden space-y-8">

          <!-- Welcome -->
          <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-6">
            <p class="text-ibt-text-light text-sm">ようこそ</p>
            <p id="parent-name" class="text-xl font-bold text-ibt-text">田中 太郎 さま</p>
          </div>

          <!-- Ticket Balance Cards -->
          <div>
            <h3 class="font-bold text-ibt-text text-lg mb-4">チケット残数</h3>
            <div id="parent-ticket-cards" class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              <!-- Injected by JS -->
            </div>
          </div>

          <!-- Action Buttons -->
          <div class="flex flex-wrap gap-3">
            <a href="/lesson-tickets/" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-ibt-gradient-start to-ibt-gradient-end text-white font-bold rounded-full hover:shadow-lg transition-shadow">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /></svg>
              チケット購入
            </a>
            <a href="/contact/" class="inline-flex items-center gap-2 px-6 py-3 bg-white text-ibt-text font-bold border-2 border-ibt-border rounded-full hover:border-ibt-red hover:text-ibt-red transition-colors">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" /></svg>
              新しい予約
            </a>
          </div>

          <!-- Upcoming Bookings -->
          <div>
            <h3 class="font-bold text-ibt-text text-lg mb-4">今後の予約</h3>
            <div class="bg-white rounded-2xl shadow-sm border border-ibt-border overflow-hidden">
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead class="bg-gray-50 border-b border-ibt-border">
                    <tr>
                      <th class="text-left px-4 py-3 font-medium text-ibt-text-light">日時</th>
                      <th class="text-left px-4 py-3 font-medium text-ibt-text-light">プログラム</th>
                      <th class="text-left px-4 py-3 font-medium text-ibt-text-light">講師</th>
                      <th class="text-left px-4 py-3 font-medium text-ibt-text-light">形式</th>
                    </tr>
                  </thead>
                  <tbody id="parent-upcoming-bookings">
                    <!-- Injected by JS -->
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- Past Lessons -->
          <div>
            <h3 class="font-bold text-ibt-text text-lg mb-4">過去の授業履歴</h3>
            <div class="bg-white rounded-2xl shadow-sm border border-ibt-border overflow-hidden">
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead class="bg-gray-50 border-b border-ibt-border">
                    <tr>
                      <th class="text-left px-4 py-3 font-medium text-ibt-text-light">日時</th>
                      <th class="text-left px-4 py-3 font-medium text-ibt-text-light">プログラム</th>
                      <th class="text-left px-4 py-3 font-medium text-ibt-text-light">講師</th>
                      <th class="text-left px-4 py-3 font-medium text-ibt-text-light">ステータス</th>
                    </tr>
                  </thead>
                  <tbody id="parent-past-lessons">
                    <!-- Injected by JS -->
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== TEACHER VIEW ===== -->
    <section id="view-teacher" class="hidden py-12 md:py-16 bg-ibt-bg">
      <div class="max-w-5xl mx-auto px-4">

        <!-- Back & Title -->
        <div class="flex items-center gap-4 mb-8">
          <button class="back-to-role text-ibt-text-light hover:text-ibt-red transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
          </button>
          <div>
            <p class="text-ibt-red font-bold text-sm tracking-widest">TEACHER DASHBOARD</p>
            <h2 class="text-2xl md:text-3xl font-bold text-ibt-text">講師ダッシュボード</h2>
          </div>
        </div>

        <!-- Teacher Selector -->
        <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-6 mb-8">
          <h3 class="font-bold text-ibt-text text-lg mb-4">講師を選択</h3>
          <div id="teacher-selector" class="flex flex-wrap gap-3">
            <!-- Injected by JS -->
          </div>
        </div>

        <!-- Teacher Dashboard Content -->
        <div id="teacher-dashboard" class="hidden space-y-8">

          <!-- Today's Schedule -->
          <div>
            <h3 class="font-bold text-ibt-text text-lg mb-4">今日のスケジュール</h3>
            <div id="teacher-today" class="space-y-3">
              <!-- Injected by JS -->
            </div>
          </div>

          <!-- This Week's Bookings -->
          <div>
            <h3 class="font-bold text-ibt-text text-lg mb-4">今週の予約</h3>
            <div class="bg-white rounded-2xl shadow-sm border border-ibt-border overflow-hidden">
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead class="bg-gray-50 border-b border-ibt-border">
                    <tr>
                      <th class="text-left px-4 py-3 font-medium text-ibt-text-light">日時</th>
                      <th class="text-left px-4 py-3 font-medium text-ibt-text-light">生徒</th>
                      <th class="text-left px-4 py-3 font-medium text-ibt-text-light">プログラム</th>
                      <th class="text-left px-4 py-3 font-medium text-ibt-text-light">形式</th>
                    </tr>
                  </thead>
                  <tbody id="teacher-weekly-bookings">
                    <!-- Injected by JS -->
                  </tbody>
                </table>
              </div>
            </div>
          </div>

          <!-- Student List -->
          <div>
            <h3 class="font-bold text-ibt-text text-lg mb-4">担当生徒一覧</h3>
            <div class="bg-white rounded-2xl shadow-sm border border-ibt-border overflow-hidden">
              <div class="overflow-x-auto">
                <table class="w-full text-sm">
                  <thead class="bg-gray-50 border-b border-ibt-border">
                    <tr>
                      <th class="text-left px-4 py-3 font-medium text-ibt-text-light">生徒名</th>
                      <th class="text-left px-4 py-3 font-medium text-ibt-text-light">プログラム</th>
                      <th class="text-left px-4 py-3 font-medium text-ibt-text-light">チケット残数</th>
                      <th class="text-left px-4 py-3 font-medium text-ibt-text-light">最終授業</th>
                    </tr>
                  </thead>
                  <tbody id="teacher-student-list">
                    <!-- Injected by JS -->
                  </tbody>
                </table>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== ADMIN VIEW ===== -->
    <section id="view-admin" class="hidden py-12 md:py-16 bg-ibt-bg">
      <div class="max-w-6xl mx-auto px-4">

        <!-- Back & Title -->
        <div class="flex items-center gap-4 mb-8">
          <button class="back-to-role text-ibt-text-light hover:text-ibt-red transition-colors">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg>
          </button>
          <div>
            <p class="text-ibt-red font-bold text-sm tracking-widest">ADMIN DASHBOARD</p>
            <h2 class="text-2xl md:text-3xl font-bold text-ibt-text">管理者ダッシュボード</h2>
          </div>
        </div>

        <!-- Overview Stats -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
          <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-5 text-center">
            <p class="text-ibt-text-light text-sm mb-1">総生徒数</p>
            <p id="admin-total-students" class="text-3xl font-bold text-ibt-text">--</p>
          </div>
          <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-5 text-center">
            <p class="text-ibt-text-light text-sm mb-1">販売チケット総数</p>
            <p id="admin-total-tickets" class="text-3xl font-bold text-ibt-text">--</p>
          </div>
          <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-5 text-center">
            <p class="text-ibt-text-light text-sm mb-1">今週のレッスン</p>
            <p id="admin-weekly-lessons" class="text-3xl font-bold text-ibt-text">--</p>
          </div>
          <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-5 text-center">
            <p class="text-ibt-text-light text-sm mb-1">チケット残少アラート</p>
            <p id="admin-low-balance" class="text-3xl font-bold text-red-500">--</p>
          </div>
        </div>

        <!-- Admin Tabs -->
        <div class="flex flex-wrap gap-2 mb-6">
          <button data-admin-tab="alerts" class="admin-tab active-admin-tab px-5 py-2.5 rounded-full font-medium text-sm transition-all">残少アラート</button>
          <button data-admin-tab="orders" class="admin-tab px-5 py-2.5 rounded-full font-medium text-sm transition-all">最近の注文</button>
          <button data-admin-tab="actions" class="admin-tab px-5 py-2.5 rounded-full font-medium text-sm transition-all">クイック操作</button>
        </div>

        <!-- Low Balance Alerts -->
        <div id="admin-tab-alerts" class="admin-tab-content">
          <div class="bg-white rounded-2xl shadow-sm border border-ibt-border overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead class="bg-gray-50 border-b border-ibt-border">
                  <tr>
                    <th class="text-left px-4 py-3 font-medium text-ibt-text-light">生徒名</th>
                    <th class="text-left px-4 py-3 font-medium text-ibt-text-light">プログラム</th>
                    <th class="text-left px-4 py-3 font-medium text-ibt-text-light">残数</th>
                    <th class="text-left px-4 py-3 font-medium text-ibt-text-light">保護者メール</th>
                  </tr>
                </thead>
                <tbody id="admin-alerts-body">
                  <!-- Injected by JS -->
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Recent Orders -->
        <div id="admin-tab-orders" class="admin-tab-content hidden">
          <div class="bg-white rounded-2xl shadow-sm border border-ibt-border overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead class="bg-gray-50 border-b border-ibt-border">
                  <tr>
                    <th class="text-left px-4 py-3 font-medium text-ibt-text-light">日付</th>
                    <th class="text-left px-4 py-3 font-medium text-ibt-text-light">保護者</th>
                    <th class="text-left px-4 py-3 font-medium text-ibt-text-light">プログラム</th>
                    <th class="text-left px-4 py-3 font-medium text-ibt-text-light">枚数</th>
                    <th class="text-left px-4 py-3 font-medium text-ibt-text-light">金額</th>
                  </tr>
                </thead>
                <tbody id="admin-orders-body">
                  <!-- Injected by JS -->
                </tbody>
              </table>
            </div>
          </div>
        </div>

        <!-- Quick Actions -->
