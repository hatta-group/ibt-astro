---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="お問い合わせ・無料体験申込｜IB専門家庭教師IBT"
  description="IB専門家庭教師IBTへのお問い合わせ・無料体験のお申し込みはこちら。60分の無料体験授業でIB卒業生講師の指導を体験できます。"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://ib-tutors.net/" },
        { "@type": "ListItem", "position": 2, "name": "お問い合わせ・無料体験申込", "item": "https://ib-tutors.net/contact/" }
      ]
    })} />
  </Fragment>

  <!-- Page Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/85 text-sm mb-6" aria-label="パンくずリスト">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <span class="text-white">お問い合わせ・無料体験申込</span>
      </nav>
      <h1 class="text-3xl md:text-5xl font-bold text-white">お問い合わせ・無料体験申込</h1>
      <p class="mt-4 text-white/80 text-lg">まずは60分の無料体験からお気軽にどうぞ</p>
    </div>
  </section>

  {Astro.url.searchParams.get('sent') === 'true' && (
    <section class="py-6 bg-emerald-50">
      <div class="max-w-7xl mx-auto px-4">
        <div class="bg-white border border-emerald-200 rounded-2xl p-6 text-center">
          <div class="w-12 h-12 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-3">
            <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
          </div>
          <h2 class="text-xl font-bold text-emerald-800 mb-2">送信完了しました！</h2>
          <p class="text-emerald-600">24時間以内にご返信いたします。しばらくお待ちください。</p>
        </div>
      </div>
    </section>
  )}

  <!-- Form + Info -->
  <section class="py-16 md:py-24 bg-ibt-bg">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
        <!-- Left: Contact Form -->
        <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8">
          <h2 class="text-xl font-bold text-ibt-text mb-6">お問い合わせフォーム</h2>
          <form id="ibt-contact-form" class="space-y-5">
            <input type="hidden" name="_subject" value="【IBT】新規お問合せ" />
            <input type="text" name="_gotcha" style="display:none" />
            <!-- お名前 -->
            <div>
              <label for="name" class="block text-sm font-medium text-ibt-text mb-1">
                お名前 <span class="text-ibt-red">*</span>
              </label>
              <input
                type="text"
                id="name"
                name="name"
                required
                autocomplete="name"
                placeholder="例: 山田 太郎"
                aria-required="true"
                class="w-full border border-ibt-border rounded-lg px-4 py-3 text-ibt-text placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-ibt-red/30 focus:border-ibt-red transition-colors"
              />
            </div>

            <!-- メールアドレス -->
            <div>
              <label for="email" class="block text-sm font-medium text-ibt-text mb-1">
                メールアドレス <span class="text-ibt-red">*</span>
              </label>
              <input
                type="email"
                id="email"
                name="email"
                required
                autocomplete="email"
                placeholder="例: example@email.com"
                aria-required="true"
                class="w-full border border-ibt-border rounded-lg px-4 py-3 text-ibt-text placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-ibt-red/30 focus:border-ibt-red transition-colors"
              />
            </div>

            <!-- 電話番号 -->
            <div>
              <label for="tel" class="block text-sm font-medium text-ibt-text mb-1">
                電話番号
              </label>
              <input
                type="tel"
                id="tel"
                name="tel"
                autocomplete="tel"
                placeholder="例: 090-1234-5678"
                class="w-full border border-ibt-border rounded-lg px-4 py-3 text-ibt-text placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-ibt-red/30 focus:border-ibt-red transition-colors"
              />
            </div>

            <!-- 学年・プログラム -->
            <div>
              <label for="program" class="block text-sm font-medium text-ibt-text mb-1">
                お子様の学年・プログラム
              </label>
              <select
                id="program"
                name="program"
                class="w-full border border-ibt-border rounded-lg px-4 py-3 text-ibt-text bg-white focus:outline-none focus:ring-2 focus:ring-ibt-red/30 focus:border-ibt-red transition-colors"
              >
                <option value="">選択してください</option>
                <option value="pyp">PYP</option>
                <option value="myp">MYP</option>
                <option value="dp1">DP Year 1</option>
                <option value="dp2">DP Year 2</option>
                <option value="other">その他</option>
              </select>
            </div>

            <!-- お問い合わせ種別 -->
            <div>
              <label for="inquiry-type" class="block text-sm font-medium text-ibt-text mb-1">
                お問い合わせ種別
              </label>
              <select
                id="inquiry-type"
                name="inquiry-type"
                class="w-full border border-ibt-border rounded-lg px-4 py-3 text-ibt-text bg-white focus:outline-none focus:ring-2 focus:ring-ibt-red/30 focus:border-ibt-red transition-colors"
              >
                <option value="">選択してください</option>
                <option value="trial">無料体験申込</option>
                <option value="lesson">授業について</option>
                <option value="pricing">料金について</option>
                <option value="other">その他</option>
              </select>
            </div>

            <!-- メッセージ -->
            <div>
              <label for="message" class="block text-sm font-medium text-ibt-text mb-1">
                メッセージ
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                placeholder="ご質問やご要望がございましたらお書きください"
                class="w-full border border-ibt-border rounded-lg px-4 py-3 text-ibt-text placeholder:text-gray-400 focus:outline-none focus:ring-2 focus:ring-ibt-red/30 focus:border-ibt-red transition-colors resize-vertical"
              ></textarea>
            </div>

            <p id="form-helper-response" class="text-xs text-ibt-text-light">
              ※ 返信は通常24時間以内にいたします。
            </p>
            <p id="form-helper-privacy" class="text-xs text-ibt-text-light">
              送信いただいた個人情報は、お問い合わせへの対応にのみ使用いたします。詳しくは<a href="/privacy/" class="text-ibt-red hover:underline">プライバシーポリシー</a>をご確認ください。
            </p>

            <!-- プライバシー同意 -->
            <div class="flex items-start gap-3">
              <input
                type="checkbox"
                id="privacy-consent"
                name="privacy-consent"
                required
                aria-required="true"
                class="mt-1 w-4 h-4 text-ibt-red border-ibt-border rounded focus:ring-ibt-red/30 cursor-pointer"
              />
              <label for="privacy-consent" class="text-sm text-ibt-text cursor-pointer">
                <a href="/privacy/" target="_blank" class="text-ibt-red hover:underline">プライバシーポリシー</a>に同意します <span class="text-ibt-red">*</span>
              </label>
            </div>

            <!-- エラーメッセージ -->
            <div id="form-error" class="hidden">
              <p class="text-ibt-red text-sm"></p>
            </div>

            <!-- 送信ボタン -->
            <div aria-live="polite" id="form-errors" class="sr-only"></div>
            <button
              type="submit"
              id="submit-btn"
              aria-describedby="form-helper-response form-helper-privacy"
              class="w-full bg-gradient-to-r from-ibt-gradient-start to-ibt-gradient-end text-white font-bold px-8 py-4 rounded-full hover:shadow-lg transition-shadow"
            >
              送信する
            </button>
          </form>

          <!-- サンクスメッセージ（送信後の導線強化） -->
          <div id="thank-you-message" class="hidden py-12">
            <div class="text-center mb-8">
              <div class="w-16 h-16 bg-emerald-100 rounded-full flex items-center justify-center mx-auto mb-4">
                <svg class="w-8 h-8 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
              </div>
              <h3 class="text-2xl font-bold text-emerald-800 mb-2">送信完了しました！</h3>
              <p class="text-emerald-600 text-lg">ありがとうございます。</p>
            </div>

            <!-- 次のステップ -->
            <div class="bg-gray-50 rounded-2xl p-6 mb-6">
              <h4 class="font-bold text-ibt-text mb-4 text-center">これからの流れ</h4>
              <div class="space-y-4">
                <div class="flex items-start gap-4">
                  <div class="shrink-0 w-8 h-8 bg-ibt-red text-white rounded-full flex items-center justify-center text-sm font-bold">1</div>
                  <div>
                    <p class="font-bold text-ibt-text">確認メールをお送りします</p>
                    <p class="text-sm text-ibt-text-light">24時間以内にメールでご連絡いたします。届かない場合は迷惑メールフォルダもご確認ください。</p>
                  </div>
                </div>
                <div class="flex items-start gap-4">
                  <div class="shrink-0 w-8 h-8 bg-ibt-red text-white rounded-full flex items-center justify-center text-sm font-bold">2</div>
                  <div>
                    <p class="font-bold text-ibt-text">無料体験の日程調整</p>
                    <p class="text-sm text-ibt-text-light">ご希望の日時・科目をお伺いし、最適な講師をご提案します。</p>
                  </div>
                </div>
                <div class="flex items-start gap-4">
                  <div class="shrink-0 w-8 h-8 bg-ibt-red text-white rounded-full flex items-center justify-center text-sm font-bold">3</div>
                  <div>
                    <p class="font-bold text-ibt-text">60分の無料体験授業</p>
                    <p class="text-sm text-ibt-text-light">IB卒業生講師がマンツーマンで指導します。体験後に入会を強制することは一切ありません。</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- LINE誘導 -->
            <div class="bg-[#06C755]/10 rounded-2xl p-6 text-center">
              <p class="font-bold text-ibt-text mb-2">お急ぎの方はLINEでも相談できます</p>
              <p class="text-sm text-ibt-text-light mb-4">チャットで気軽にご質問いただけます</p>
              <a href="https://line.me/R/ti/p/@974okamx" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 px-6 py-3 bg-[#06C755] text-white font-bold rounded-full hover:bg-[#05b34c] transition-colors">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
                LINEで相談する
              </a>
            </div>
          </div>
        </div>

        <!-- Right: Info Cards -->
        <div class="space-y-6">
          <!-- 60分無料体験 -->
          <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8">
            <div class="flex items-start gap-4">
              <div class="shrink-0 w-12 h-12 bg-ibt-red-50 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-ibt-red" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-ibt-text mb-2">60分無料体験</h3>
                <p class="text-ibt-text-light leading-relaxed">
                  IB卒業生講師によるマンツーマン指導を60分間無料で体験できます。お子様の学習状況を把握し、最適な学習プランをご提案します。
                </p>
              </div>
            </div>
          </div>

          <!-- 入会金0円 -->
          <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8">
            <div class="flex items-start gap-4">
              <div class="shrink-0 w-12 h-12 bg-ibt-red-50 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-ibt-red" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-ibt-text mb-2">入会金0円</h3>
                <p class="text-ibt-text-light leading-relaxed">
                  入会金は一切かかりません。授業料のみのチケット制で、長期契約や違約金もなく安心してスタートできます。
                </p>
              </div>
            </div>
          </div>

          <!-- レスポンス -->
          <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8">
            <div class="flex items-start gap-4">
              <div class="shrink-0 w-12 h-12 bg-ibt-red-50 rounded-xl flex items-center justify-center">
                <svg class="w-6 h-6 text-ibt-red" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                </svg>
              </div>
              <div>
                <h3 class="text-lg font-bold text-ibt-text mb-2">スピード対応</h3>
                <p class="text-ibt-text-light leading-relaxed">
                  お問い合わせには通常24時間以内にご返信いたします。お急ぎの方もお気軽にご連絡ください。
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('ibt-contact-form') as HTMLFormElement | null;
  const errorDiv = document.getElementById('form-error');
  const errorText = errorDiv?.querySelector('p');
  const thankYouMessage = document.getElementById('thank-you-message');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;

  function showFormError(message: string) {
    if (errorDiv && errorText) {
      errorText.textContent = message;
      errorDiv.classList.remove('hidden');
    }
  }

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      errorDiv?.classList.add('hidden');

      // Clear previous field errors
      form.querySelectorAll('.field-error').forEach(el => el.remove());
      form.querySelectorAll('.border-red-400').forEach(el => {
        el.classList.remove('border-red-400');
        el.classList.add('border-ibt-border');
      });

      const name = (form.querySelector('#name') as HTMLInputElement)?.value?.trim();
      const email = (form.querySelector('#email') as HTMLInputElement)?.value?.trim();
      const privacyConsent = form.querySelector('#privacy-consent') as HTMLInputElement | null;

      if (!name) { showFormError('お名前を入力してください。'); return; }
      if (!email) { showFormError('メールアドレスを入力してください。'); return; }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { showFormError('正しいメールアドレスを入力してください。'); return; }
      if (privacyConsent && !privacyConsent.checked) { showFormError('個人情報の取り扱いに同意してください。'); return; }

      if (submitBtn) { submitBtn.disabled = true; submitBtn.textContent = '送信中...'; }

      try {
        const formData = new FormData(form);
        formData.delete('privacy-consent');

        const response = await fetch('https://formspree.io/f/mdapzogd', {
          method: 'POST',
          body: formData,
          headers: { 'Accept': 'application/json' },
        });

        if (response.ok) {
          // GA4: フォーム送信成功イベント
          if (typeof gtag === 'function') {
            gtag('event', 'form_submit_contact', {
              event_category: 'engagement',
              event_label: 'contact_form',
            });
          }
          form.classList.add('hidden');
          if (thankYouMessage) thankYouMessage.classList.remove('hidden');
        } else {
          showFormError('送信に失敗しました。しばらく経ってからもう一度お試しください。');
          if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = '送信する'; }
        }
      } catch {
        showFormError('送信中にエラーが発生しました。ネットワーク接続を確認して再度お試しください。');
        if (submitBtn) { submitBtn.disabled = false; submitBtn.textContent = '送信する'; }
      }
    });
  }
</script>
