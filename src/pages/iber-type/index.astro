---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { iberTypes } from '../../data/iber-types';
---

<BaseLayout
  title="IBerタイプ一覧｜IB Learner's Profileの10タイプを徹底解説｜IBT"
  description="IB Learner's Profileの10タイプを徹底解説。Inquirer・Thinker・Caringなど、各タイプの特徴と強みの活かし方をIB専門家庭教師が紹介。"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://ib-tutors.net/" },
        { "@type": "ListItem", "position": 2, "name": "IBerタイプ一覧", "item": "https://ib-tutors.net/iber-type/" }
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/85 text-sm mb-6">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <span class="text-white">IBerタイプ一覧</span>
      </nav>
      <h1 class="text-3xl md:text-5xl font-bold text-white">IBerタイプ一覧</h1>
      <p class="mt-4 text-white/85 text-lg md:text-xl">IB Learner's Profileの10の学習者像を知ろう</p>
    </div>
  </section>

  <!-- Intro -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="text-ibt-red font-bold text-sm tracking-widest mb-4">IB LEARNER PROFILE</p>
      <h2 class="text-2xl md:text-4xl font-bold mb-6">IB Learner's Profileとは？</h2>
      <div class="w-16 h-1 bg-gradient-to-r from-ibt-gradient-start to-ibt-gradient-end mx-auto mb-8 rounded-full"></div>
      <p class="text-ibt-text-light text-lg leading-relaxed">
        IB Learner's Profile（学習者像）は、国際バカロレア（IB）が定義する「理想の学習者」の姿です。
      </p>
      <p class="text-ibt-text-light text-lg leading-relaxed mt-3">
        10のタイプそれぞれが持つ特性を理解することで、自分の強みを活かした学習ができるようになります。IBの全プログラム（PYP・MYP・DP）に共通する、学びの土台となる考え方です。
      </p>
    </div>
  </section>

  <!-- Type Grid -->
  <section class="py-16 md:py-24 bg-ibt-bg">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12 md:mb-16">
        <p class="text-ibt-red font-bold text-sm tracking-widest mb-4">10 TYPES</p>
        <h2 class="text-2xl md:text-4xl font-bold">10のIBerタイプ</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {iberTypes.map((type) => (
          <a
            href={`/iber-type/${type.id}/`}
            class="group relative rounded-2xl overflow-hidden hover:shadow-xl hover:-translate-y-2 transition-all duration-300"
          >
            {/* Colored background gradient */}
            <div class="absolute inset-0 opacity-[0.07] group-hover:opacity-[0.12] transition-opacity duration-300" style={`background: linear-gradient(135deg, ${type.color}, ${type.color}80)`}></div>
            <div class="absolute top-0 left-0 right-0 h-24" style={`background: linear-gradient(180deg, ${type.color}15, transparent)`}></div>

            <div class="relative border border-gray-200 group-hover:border-transparent rounded-2xl bg-white/80 backdrop-blur-sm">
              {/* Top color bar */}
              <div class="h-1.5 rounded-t-2xl" style={`background: linear-gradient(90deg, ${type.color}, ${type.color}99)`}></div>

              <div class="p-8">
                {/* Character + Name */}
                <div class="flex items-center gap-5 mb-6">
                  <div class="w-24 h-24 shrink-0 rounded-2xl p-2 shadow-sm group-hover:scale-110 transition-transform duration-300" style={`background: linear-gradient(135deg, ${type.color}15, ${type.color}05)`}>
                    <img
                      src={`/images/iber-types/${type.id}.webp`}
                      alt={`${type.name} - ${type.nameJa}`}
                      class="w-full h-full object-contain drop-shadow-md"
                      loading="lazy"
                    />
                  </div>
                  <div>
                    <h3 class="text-2xl font-black group-hover:tracking-wide transition-all duration-300" style={`color: ${type.color}`}>{type.name}</h3>
                    <p class="text-sm text-gray-500 font-bold mt-0.5">{type.nameJa}</p>
                    <div class="w-10 h-1 mt-2 rounded-full transition-all duration-300 group-hover:w-16" style={`background: linear-gradient(90deg, ${type.color}, ${type.color}60)`}></div>
                  </div>
                </div>

                {/* Description */}
                <p class="text-gray-500 leading-relaxed text-sm mb-6">{type.description}</p>

                {/* CTA */}
                <div class="flex items-center justify-between">
                  <span class="font-bold text-sm group-hover:translate-x-1 transition-transform inline-flex items-center gap-1.5" style={`color: ${type.color}`}>
                    詳しく見る
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
                  </span>
                  <span class="text-xs px-3 py-1 rounded-full font-bold opacity-60 group-hover:opacity-100 transition-opacity" style={`background-color: ${type.color}15; color: ${type.color}`}>
                    {type.id === 'inquirer' ? '探究' : type.id === 'knowledgeable' ? '知識' : type.id === 'thinker' ? '論理' : type.id === 'communicator' ? '表現' : type.id === 'principled' ? '信念' : type.id === 'open-minded' ? '視野' : type.id === 'caring' ? '共感' : type.id === 'risk-taker' ? '挑戦' : type.id === 'balanced' ? '調和' : '内省'}
                  </span>
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Diagnosis CTA -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <div class="bg-ibt-red-50 rounded-2xl p-10 md:p-14">
        <div class="w-16 h-16 bg-white rounded-full flex items-center justify-center mx-auto mb-6 shadow-sm">
          <svg class="w-8 h-8 text-ibt-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
          </svg>
        </div>
        <h2 class="text-2xl md:text-3xl font-bold mb-4">あなたはどのタイプ？</h2>
        <p class="text-ibt-text-light mb-8">たった15問の診断で、あなたのIBerタイプがわかります。</p>
        <a
          href="/iber-type-shindan/"
          class="inline-block bg-gradient-to-r from-ibt-gradient-start to-ibt-gradient-end text-white font-bold px-8 py-4 rounded-full hover:shadow-lg transition-shadow text-lg"
        >
          IBerタイプ診断を受ける
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-ibt-bg">
    <div class="max-w-7xl mx-auto px-4">
      <div class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end rounded-2xl p-10 md:p-16 text-center">
        <h2 class="text-2xl md:text-4xl font-bold text-white mb-4">IBTで自分の強みを活かそう</h2>
        <p class="text-white/80 mb-8 text-lg max-w-xl mx-auto">
          あなたのタイプに合った学習法を、IB卒業生の講師がご提案します。60分の無料体験で実感してください。
        </p>
        <a
          href="/contact/"
          class="inline-block bg-white text-ibt-red font-bold px-8 py-4 rounded-full hover:bg-ibt-red-light transition-colors text-lg shadow-lg"
        >
          60分無料体験に申し込む
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
