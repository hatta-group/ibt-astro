---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const types = await getCollection('iber-types');
  return types.map((type) => ({
    params: { slug: type.data.slug },
    props: { type },
  }));
}

const { type } = Astro.props;
const { Content } = await render(type);
---

<BaseLayout
  title={`${type.data.title}｜IBT`}
  description={type.data.description}
>
  <!-- Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/70 text-sm mb-6">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/iber-type/" class="hover:text-white transition-colors">IBerタイプ一覧</a>
        <span class="mx-2">/</span>
        <span class="text-white">{type.data.title}</span>
      </nav>
      <div class="flex items-center gap-4">
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center text-white text-2xl font-black" style={`background-color: ${type.data.color}`}>
          {type.data.title.charAt(0)}
        </div>
        <h1 class="text-2xl md:text-4xl font-bold text-white">{type.data.title}</h1>
      </div>
    </div>
  </section>

  <!-- Color Accent Bar -->
  <div class="h-1.5" style={`background-color: ${type.data.color}`}></div>

  <!-- Content -->
  <article class="py-16 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 prose prose-lg prose-gray
      prose-headings:font-black prose-headings:text-ibt-text
      prose-a:text-ibt-red prose-a:no-underline hover:prose-a:underline
      prose-strong:text-ibt-text
      prose-img:rounded-xl
      prose-table:border-collapse prose-td:border prose-td:border-ibt-border prose-td:px-4 prose-td:py-2
      prose-th:border prose-th:border-ibt-border prose-th:px-4 prose-th:py-2 prose-th:bg-ibt-bg">
      <Content />
    </div>
  </article>

  <!-- Diagnosis Link -->
  <section class="py-12 bg-ibt-bg">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8">
        <p class="text-ibt-red font-bold text-sm tracking-widest mb-3">IB LEARNER PROFILE</p>
        <h2 class="text-xl md:text-2xl font-bold mb-4">あなたのIBerタイプは？</h2>
        <p class="text-ibt-text-light mb-6">
          IB Learner's Profileに基づく診断で、あなたの強みと伸ばすべきポイントを発見しましょう。
        </p>
        <a
          href="/iber-type-shindan/"
          class="inline-block px-6 py-3 border-2 border-ibt-red text-ibt-red font-bold rounded-full hover:bg-ibt-red hover:text-white transition-colors"
        >
          IBerタイプ診断を受ける
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">IBの学習でお困りですか？</h2>
      <p class="text-ibt-text-light text-lg mb-8">
        IB卒業生の専門家庭教師がマンツーマンでサポートします。まずは60分の無料体験をお試しください。
      </p>
      <a
        href="/contact/"
        class="inline-block px-8 py-4 bg-ibt-red text-white font-bold rounded-full shadow-lg hover:bg-ibt-red-dark transition-colors cta-pulse"
      >
        60分無料体験に申し込む
      </a>
    </div>
  </section>
</BaseLayout>
