---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="特定商取引法に基づく表記｜IBT"
  description="IB専門家庭教師IBTの特定商取引法に基づく表記です。"
  noindex={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://ib-tutors.net/" },
        { "@type": "ListItem", "position": 2, "name": "特定商取引法に基づく表記", "item": "https://ib-tutors.net/legal/" }
      ]
    })} />
  </Fragment>

  <!-- Page Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/70 text-sm mb-6">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <span class="text-white">特定商取引法に基づく表記</span>
      </nav>
      <h1 class="text-3xl md:text-5xl font-bold text-white">特定商取引法に基づく表記</h1>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 md:py-24 bg-ibt-bg">
    <div class="max-w-3xl mx-auto px-4">
      <div class="bg-white rounded-2xl shadow-sm border border-ibt-border overflow-hidden">
        <table class="w-full text-left">
          <tbody class="divide-y divide-ibt-border">
            <tr>
              <th class="px-6 py-5 bg-gray-50 text-sm font-medium text-ibt-text w-1/3 align-top">事業者名</th>
              <td class="px-6 py-5 text-sm text-ibt-text-light">IBT（IB Tutors）</td>
            </tr>
            <tr>
              <th class="px-6 py-5 bg-gray-50 text-sm font-medium text-ibt-text w-1/3 align-top">運営</th>
              <td class="px-6 py-5 text-sm text-ibt-text-light">HATTAFUND Inc.</td>
            </tr>
            <tr>
              <th class="px-6 py-5 bg-gray-50 text-sm font-medium text-ibt-text w-1/3 align-top">代表者</th>
              <td class="px-6 py-5 text-sm text-ibt-text-light italic">公開時に記載</td>
            </tr>
            <tr>
              <th class="px-6 py-5 bg-gray-50 text-sm font-medium text-ibt-text w-1/3 align-top">所在地</th>
              <td class="px-6 py-5 text-sm text-ibt-text-light italic">公開時に記載</td>
            </tr>
            <tr>
              <th class="px-6 py-5 bg-gray-50 text-sm font-medium text-ibt-text w-1/3 align-top">連絡先</th>
              <td class="px-6 py-5 text-sm text-ibt-text-light italic">公開時に記載</td>
            </tr>
            <tr>
              <th class="px-6 py-5 bg-gray-50 text-sm font-medium text-ibt-text w-1/3 align-top">サービス内容</th>
              <td class="px-6 py-5 text-sm text-ibt-text-light">IB国際バカロレア専門の個別指導サービス</td>
            </tr>
            <tr>
              <th class="px-6 py-5 bg-gray-50 text-sm font-medium text-ibt-text w-1/3 align-top">料金</th>
              <td class="px-6 py-5 text-sm text-ibt-text-light">個別にお見積もり（入会金0円・都度払い制）</td>
            </tr>
            <tr>
              <th class="px-6 py-5 bg-gray-50 text-sm font-medium text-ibt-text w-1/3 align-top">支払方法</th>
              <td class="px-6 py-5 text-sm text-ibt-text-light italic">公開時に記載</td>
            </tr>
            <tr>
              <th class="px-6 py-5 bg-gray-50 text-sm font-medium text-ibt-text w-1/3 align-top">支払時期</th>
              <td class="px-6 py-5 text-sm text-ibt-text-light">授業実施後の都度払い</td>
            </tr>
            <tr>
              <th class="px-6 py-5 bg-gray-50 text-sm font-medium text-ibt-text w-1/3 align-top">キャンセル</th>
              <td class="px-6 py-5 text-sm text-ibt-text-light">授業前日までにご連絡ください</td>
            </tr>
            <tr>
              <th class="px-6 py-5 bg-gray-50 text-sm font-medium text-ibt-text w-1/3 align-top">返金</th>
              <td class="px-6 py-5 text-sm text-ibt-text-light">未実施の授業料は全額返金</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>
</BaseLayout>
