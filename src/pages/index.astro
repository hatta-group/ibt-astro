---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { tutors } from '../data/tutors';
import { faqItems } from '../data/faq';

const previewTutors = tutors.slice(0, 3);
const previewFaq = faqItems.slice(0, 5);

const stats = [
  { label: 'IB卒業生講師', value: '100%' },
  { label: '対応科目数', value: '全科目' },
  { label: '無料体験', value: '60分' },
  { label: '入会金', value: '0円' },
];

const features = [
  {
    title: 'IB卒業生だけの講師陣',
    description: 'IB経験者だから分かるコツ・勉強法を直接伝授。教科書には載っていない実践的なノウハウで、効率的にスコアアップを実現します。',
    icon: '🎓',
  },
  {
    title: '全科目マンツーマン対応',
    description: 'PYP・MYP・DP、さらにTOK・EE・IAまで全てカバー。一人ひとりの弱点に合わせた完全個別指導で着実に成績を伸ばします。',
    icon: '📚',
  },
  {
    title: '入会金0円・チケット制',
    description: '長期契約なし、違約金なし。無料体験から気軽にスタートできます。必要な時に必要な分だけ受講可能です。',
    icon: '💰',
  },
];

const programs = [
  {
    name: 'PYP',
    fullName: 'Primary Years Programme',
    grades: '3〜12歳',
    description: '探究心を育むIBの初等プログラム。英語での学習習慣づくりから教科サポートまで、楽しく学べる環境を提供します。',
  },
  {
    name: 'MYP',
    fullName: 'Middle Years Programme',
    grades: '11〜16歳',
    description: '教科横断的な学びを深めるIBの中等プログラム。各教科の評価基準に沿った指導で、DPへの準備を万全にします。',
  },
  {
    name: 'DP',
    fullName: 'Diploma Programme',
    grades: '16〜19歳',
    description: 'IB最終課程。6科目+TOK・EE・CASの完全対応。IB卒業生講師の指導で、高得点取得と志望大学合格を目指します。',
  },
];

const trustPoints = [
  'TOK・EE・IA完全対応',
  '日英バイリンガル対応',
  'オンライン・対面両対応',
  '海外在住者も受講可能',
];

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<BaseLayout
  title="IB家庭教師IBT｜IB卒業生が全科目指導・60分無料体験"
  description="IB専門家庭教師IBT。IB卒業生によるマンツーマン指導でPYP・MYP・DP全科目対応。TOK・EE・IA対策も万全。入会費無料・無料体験実施中。"
>
  <Fragment slot="head">
    <link rel="alternate" hreflang="ja" href="https://ib-tutors.net/" />
    <link rel="alternate" hreflang="en" href="https://ib-tutors.net/en/" />
  </Fragment>

  <!-- ===== 1. Hero Section ===== -->
  <section class="relative overflow-hidden min-h-[500px] md:min-h-[600px] flex items-center">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img src="/images/hero/hero-bg.webp" alt="IB生徒がオンラインで講師のマンツーマン指導を受けている様子" class="w-full h-full object-cover object-[center_25%]" loading="eager" fetchpriority="high" width="1920" height="1080" />
    </div>
    <!-- Dark Overlay -->
    <div class="absolute inset-0 bg-gradient-to-b from-black/10 via-black/15 to-black/50"></div>
    <!-- Content -->
    <div class="relative z-10 max-w-7xl mx-auto px-4 py-20 md:py-28 lg:py-36 w-full">
      <div class="max-w-2xl">
        <p class="text-white/80 text-sm md:text-base font-medium tracking-widest mb-4 hero-text-shadow">IB TUTORS — 国際バカロレア専門</p>
        <h1 class="text-3xl md:text-5xl lg:text-6xl font-black text-white leading-tight hero-text-shadow">
          IB卒業生が教える、<br />IB生のための家庭教師
        </h1>
        <div class="w-24 h-1 bg-ibt-red mt-6 mb-6"></div>
        <p class="text-white/90 text-base md:text-lg leading-relaxed hero-text-shadow">
          PYP・MYP・DP 全対応<br />
          オンライン＆対面 ｜ バイリンガル指導
        </p>
        <div class="mt-10 flex flex-col sm:flex-row gap-4">
          <a
            href="/contact/"
            class="inline-flex items-center justify-center bg-ibt-red text-white font-[800] text-lg px-8 py-4 rounded-full shadow-lg hover:shadow-xl hover:scale-[1.02] transition-all duration-200 cta-pulse"
          >
            まずは無料で相談する
          </a>
          <a
            href="/lessons-pricing/"
            class="inline-flex items-center justify-center text-white font-medium text-base px-6 py-4 hover:text-white/80 transition-colors"
          >
            料金を見る →
          </a>
          <a
            href="/iber-type-shindan/"
            class="inline-flex items-center justify-center text-white font-medium text-base px-6 py-4 hover:text-white/80 transition-colors"
          >
            IBerタイプ診断 →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 2. Stats Bar ===== -->
  <section class="bg-white border-b border-ibt-border">
    <div class="max-w-7xl mx-auto px-4 py-8 md:py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8">
        {stats.map((stat) => (
          <div class="text-center">
            <p class="text-2xl md:text-3xl lg:text-4xl font-black text-ibt-red">{stat.value}</p>
            <p class="mt-1 text-sm md:text-base text-ibt-text-light font-medium">{stat.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== 2.5 縛りゼロ宣言 ===== -->
  <section class="bg-gradient-to-r from-ibt-red to-[#e03e5c] py-10 md:py-14">
    <div class="max-w-5xl mx-auto px-4">
      <div class="text-center mb-8">
        <p class="text-white/80 text-sm font-medium tracking-widest mb-2">Our Promise</p>
        <h2 class="text-2xl md:text-3xl font-black text-white">IBTの約束：縛りゼロ宣言</h2>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-5 gap-4 md:gap-6 mb-8">
        <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-5 text-center">
          <p class="text-2xl md:text-3xl font-black text-white">0<span class="text-lg">円</span></p>
          <p class="text-white/90 text-xs md:text-sm font-medium mt-1">入会金</p>
        </div>
        <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-5 text-center">
          <p class="text-2xl md:text-3xl font-black text-white">0<span class="text-lg">円</span></p>
          <p class="text-white/90 text-xs md:text-sm font-medium mt-1">管理費・維持費</p>
        </div>
        <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-5 text-center">
          <p class="text-2xl md:text-3xl font-black text-white">なし</p>
          <p class="text-white/90 text-xs md:text-sm font-medium mt-1">長期契約・違約金</p>
        </div>
        <div class="bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-5 text-center">
          <p class="text-2xl md:text-3xl font-black text-white">OK</p>
          <p class="text-white/90 text-xs md:text-sm font-medium mt-1">いつでもお休み・退会</p>
        </div>
        <div class="col-span-2 md:col-span-1 bg-white/15 backdrop-blur-sm rounded-2xl p-4 md:p-5 text-center">
          <p class="text-2xl md:text-3xl font-black text-white">OK</p>
          <p class="text-white/90 text-xs md:text-sm font-medium mt-1">1回だけの受講も</p>
        </div>
      </div>
      <div class="text-center">
        <p class="text-white/90 text-sm md:text-base mb-5">まずは60分の無料体験から、お気軽にお試しください。</p>
        <a
          href="/contact/"
          class="inline-flex items-center justify-center bg-white text-ibt-red font-[800] text-base md:text-lg px-8 py-3.5 rounded-full shadow-lg hover:shadow-xl hover:scale-[1.02] transition-all duration-200"
        >
          無料体験を予約する
        </a>
      </div>
    </div>
  </section>

  <!-- ===== 3. Features / Why IBT ===== -->
  <section class="bg-ibt-bg py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12 md:mb-16">
        <p class="section-label mb-3">Why IBT</p>
        <h2 class="text-3xl md:text-4xl font-black text-ibt-text">IBTが選ばれる理由</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {features.map((feature) => (
          <div class="bg-white rounded-2xl shadow-sm hover:shadow-md transition-shadow duration-300 p-8">
            <span class="text-4xl block mb-4">{feature.icon}</span>
            <h3 class="text-xl font-bold text-ibt-text mb-3">{feature.title}</h3>
            <p class="text-ibt-text-light leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== 4. Programs ===== -->
  <section class="bg-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12 md:mb-16">
        <p class="section-label mb-3">Programs</p>
        <h2 class="text-3xl md:text-4xl font-black text-ibt-text">対応プログラム</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {programs.map((program) => (
          <div class="relative bg-white border border-ibt-border rounded-2xl shadow-sm hover:shadow-md transition-shadow duration-300 p-8 group">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-xl bg-gradient-to-br from-ibt-gradient-start to-ibt-gradient-end mb-5">
              <span class="text-white font-black text-xl">{program.name}</span>
            </div>
            <p class="text-xs text-ibt-text-light font-medium mb-1">{program.fullName}</p>
            <p class="text-sm text-ibt-red font-bold mb-3">{program.grades}</p>
            <p class="text-ibt-text-light leading-relaxed">{program.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== 5. Tutors Preview ===== -->
  <section class="bg-ibt-bg py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12 md:mb-16">
        <p class="section-label mb-3">Tutors</p>
        <h2 class="text-3xl md:text-4xl font-black text-ibt-text">講師紹介</h2>
        <p class="mt-4 text-ibt-text-light text-lg">IBTの講師は全員、現役の大学生かつIB卒業生。IBを経験したからこそ分かるリアルなアドバイスができます。</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {previewTutors.map((tutor) => (
          <div class="bg-white rounded-2xl shadow-sm hover:shadow-md transition-shadow duration-300 p-8">
            {tutor.image ? (
              <img src={tutor.image} alt={`${tutor.name}講師`} class="w-20 h-20 rounded-full object-cover mb-5" loading="lazy" width="80" height="80" />
            ) : (
              <div class="w-20 h-20 rounded-full bg-gradient-to-br from-ibt-gradient-start to-ibt-gradient-end flex items-center justify-center mb-5">
                <span class="text-white font-black text-xl">{tutor.name.charAt(0)}</span>
              </div>
            )}
            <h3 class="text-xl font-bold text-ibt-text">{tutor.name}</h3>
            <p class="text-sm text-ibt-text-light mt-1">{tutor.school} 卒</p>
            <p class="text-sm text-ibt-text-light">{tutor.university}</p>
            <div class="mt-4 flex flex-wrap gap-2">
              {tutor.subjects.map((subject) => (
                <span class="inline-block text-xs font-medium bg-ibt-red-50 text-ibt-red px-3 py-1 rounded-full">
                  {subject}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a
          href="/tutors/"
          class="inline-flex items-center text-ibt-red font-bold hover:text-ibt-red-dark transition-colors duration-200"
        >
          全ての講師を見る
          <svg class="w-5 h-5 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== 6. Trust / Features ===== -->
  <section class="bg-white py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <div class="max-w-3xl mx-auto text-center">
        <p class="section-label mb-3">Features</p>
        <h2 class="text-3xl md:text-4xl font-black text-ibt-text mb-10 md:mb-14">IBTの特徴</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
          {trustPoints.map((point) => (
            <div class="flex items-center gap-4 bg-ibt-bg rounded-xl p-5">
              <div class="flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br from-ibt-gradient-start to-ibt-gradient-end flex items-center justify-center">
                <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="text-lg font-bold text-ibt-text">{point}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ===== 6.5 Pricing Comparison ===== -->
  <section class="bg-ibt-bg py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12 md:mb-16">
        <p class="section-label mb-3">Compare</p>
        <h2 class="text-3xl md:text-4xl font-black text-ibt-text">IBTが選ばれる理由</h2>
        <p class="mt-4 text-ibt-text-light text-lg">他社と比べて、圧倒的にお得で安心</p>
      </div>
      <div class="max-w-4xl mx-auto">
        <div class="bg-white rounded-2xl shadow-sm border border-ibt-border overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-ibt-border">
                  <th class="px-4 md:px-6 py-4 text-left font-bold text-ibt-text-light"></th>
                  <th class="px-4 md:px-6 py-4 text-center">
                    <div class="inline-flex flex-col items-center">
                      <span class="bg-gradient-to-r from-ibt-gradient-start to-ibt-gradient-end text-white text-xs font-bold px-3 py-1 rounded-full mb-1">おすすめ</span>
                      <span class="font-black text-ibt-red text-lg">IBT</span>
                    </div>
                  </th>
                  <th class="px-4 md:px-6 py-4 text-center font-bold text-ibt-text-light">A社</th>
                  <th class="px-4 md:px-6 py-4 text-center font-bold text-ibt-text-light">B社</th>
                </tr>
              </thead>
              <tbody>
                <tr class="border-b border-ibt-border">
                  <td class="px-4 md:px-6 py-4 font-bold">入会金</td>
                  <td class="px-4 md:px-6 py-4 text-center">
                    <span class="text-ibt-red font-black text-xl">0円</span>
                  </td>
                  <td class="px-4 md:px-6 py-4 text-center text-ibt-text-light">22,000円</td>
                  <td class="px-4 md:px-6 py-4 text-center text-ibt-text-light">要問合せ</td>
                </tr>
                <tr class="border-b border-ibt-border">
                  <td class="px-4 md:px-6 py-4 font-bold">料金体系</td>
                  <td class="px-4 md:px-6 py-4 text-center">
                    <span class="text-ibt-red font-bold">チケット制</span>
                    <span class="block text-xs text-ibt-text-light mt-0.5">4,840円〜/回</span>
                  </td>
                  <td class="px-4 md:px-6 py-4 text-center text-ibt-text-light">時給制<span class="block text-xs mt-0.5">6,500円〜/h</span></td>
                  <td class="px-4 md:px-6 py-4 text-center text-ibt-text-light">月額制<span class="block text-xs mt-0.5">49,800円〜/月</span></td>
                </tr>
                <tr class="border-b border-ibt-border">
                  <td class="px-4 md:px-6 py-4 font-bold">講師のIB経験</td>
                  <td class="px-4 md:px-6 py-4 text-center">
                    <span class="inline-flex items-center gap-1 text-ibt-red font-bold">
                      <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                      全員IB卒業生
                    </span>
                  </td>
                  <td class="px-4 md:px-6 py-4 text-center text-ibt-text-light">一部のみ</td>
                  <td class="px-4 md:px-6 py-4 text-center text-ibt-text-light">一部のみ</td>
                </tr>
                <tr class="border-b border-ibt-border">
                  <td class="px-4 md:px-6 py-4 font-bold">PYP・MYP対応</td>
                  <td class="px-4 md:px-6 py-4 text-center">
                    <svg class="w-5 h-5 text-ibt-red mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  </td>
                  <td class="px-4 md:px-6 py-4 text-center">
                    <svg class="w-5 h-5 text-ibt-red mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  </td>
                  <td class="px-4 md:px-6 py-4 text-center">
                    <svg class="w-5 h-5 text-ibt-red mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" /></svg>
                  </td>
                </tr>
                <tr class="border-b border-ibt-border">
                  <td class="px-4 md:px-6 py-4 font-bold">無料体験</td>
                  <td class="px-4 md:px-6 py-4 text-center">
                    <span class="text-ibt-red font-bold">60分無料</span>
                  </td>
                  <td class="px-4 md:px-6 py-4 text-center text-ibt-text-light">有料</td>
                  <td class="px-4 md:px-6 py-4 text-center text-ibt-text-light">30分無料</td>
                </tr>
                <tr>
                  <td class="px-4 md:px-6 py-4 font-bold">長期契約・違約金</td>
                  <td class="px-4 md:px-6 py-4 text-center">
                    <span class="text-ibt-red font-bold">なし</span>
                  </td>
                  <td class="px-4 md:px-6 py-4 text-center text-ibt-text-light">なし</td>
                  <td class="px-4 md:px-6 py-4 text-center text-ibt-text-light">あり</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>
        <p class="text-xs text-ibt-text-light text-center mt-3">※ 2026年3月時点の公開情報に基づく比較です。A社・B社は同業他社の一般的な価格帯を参考にしています。</p>
      </div>
    </div>
  </section>

  <!-- ===== 7. Blog Preview ===== -->
  <section class="bg-ibt-bg py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-12 md:mb-16">
        <p class="section-label mb-3">Blog</p>
        <h2 class="text-3xl md:text-4xl font-black text-ibt-text">ブログ</h2>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
        {latestPosts.map((post) => (
          <a href={`/blog/${post.data.slug}/`} class="block">
            <article class="bg-white rounded-2xl shadow-sm hover:shadow-md transition-all duration-300 overflow-hidden group hover:-translate-y-1 border border-ibt-border h-full flex flex-col">
              <div class="h-1 bg-gradient-to-r from-ibt-gradient-start to-ibt-gradient-end opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
              <div class="p-6 flex flex-col flex-1">
                <time class="text-xs text-ibt-text-light">{post.data.date}</time>
                <h3 class="mt-3 text-lg font-bold text-ibt-text group-hover:text-ibt-red transition-colors duration-200 line-clamp-2">
                  {post.data.title}
                </h3>
                {post.data.description && (
                  <p class="mt-3 text-sm text-ibt-text-light leading-relaxed line-clamp-3 flex-1">{post.data.description}</p>
                )}
                <span class="inline-flex items-center text-ibt-red font-medium text-sm mt-4 group-hover:gap-1.5 gap-1 transition-all duration-200">
                  続きを読む
                  <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </span>
              </div>
            </article>
          </a>
        ))}
      </div>
      <div class="text-center mt-10">
        <a
          href="/blog/"
          class="inline-flex items-center text-ibt-red font-bold hover:text-ibt-red-dark transition-colors duration-200"
        >
          もっと読む
