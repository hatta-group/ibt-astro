---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const uniCollection = await getCollection('universities');
const slugByTitle = new Map<string, string>();
const slugByTitleEn = new Map<string, string>();
for (const u of uniCollection) {
  slugByTitle.set(u.data.title, u.data.slug);
  slugByTitleEn.set(u.data.titleEn, u.data.slug);
}

function getUniSlug(name: string): string | undefined {
  // Try matching by Japanese title first, then English title, then partial match
  if (slugByTitle.has(name)) return slugByTitle.get(name);
  if (slugByTitleEn.has(name)) return slugByTitleEn.get(name);
  // Partial match for names like "東京大学 PEAK" or "早稲田大学（一部学部）"
  for (const [title, slug] of slugByTitle) {
    if (name.includes(title) || title.includes(name)) return slug;
  }
  for (const [titleEn, slug] of slugByTitleEn) {
    if (name.includes(titleEn) || titleEn.includes(name)) return slug;
  }
  return undefined;
}

