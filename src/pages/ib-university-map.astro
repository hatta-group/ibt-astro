  <!-- Tab switching script -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const scoreRangeColors: Record<string, { tabActive: string; tab: string }> = {
        'emerald': {
          tabActive: 'bg-emerald-600 text-white border-emerald-600',
          tab: 'bg-white border-emerald-200 text-emerald-700',
        },
        'blue': {
          tabActive: 'bg-blue-600 text-white border-blue-600',
          tab: 'bg-white border-blue-200 text-blue-700',
        },
        'indigo': {
          tabActive: 'bg-indigo-600 text-white border-indigo-600',
          tab: 'bg-white border-indigo-200 text-indigo-700',
        },
        'violet': {
          tabActive: 'bg-violet-600 text-white border-violet-600',
          tab: 'bg-white border-violet-200 text-violet-700',
        },
        'amber': {
          tabActive: 'bg-amber-600 text-white border-amber-600',
          tab: 'bg-white border-amber-200 text-amber-700',
        },
      };

      const colorOrder = ['emerald', 'blue', 'indigo', 'violet', 'amber'];
      const buttons = document.querySelectorAll('.score-tab-btn');
      const panels = document.querySelectorAll('.score-panel');

      buttons.forEach((btn, idx) => {
        btn.addEventListener('click', () => {
          const target = btn.getAttribute('data-score-tab');

          buttons.forEach((b, bIdx) => {
            const c = colorOrder[bIdx];
            const colors = scoreRangeColors[c];
            // Remove all active classes
            colors.tabActive.split(' ').forEach(cls => b.classList.remove(cls));
            colors.tab.split(' ').forEach(cls => b.classList.remove(cls));
            // Add inactive classes for this button's color
            const bColor = colorOrder[bIdx];
            const bColors = scoreRangeColors[bColor];
            bColors.tab.split(' ').forEach(cls => b.classList.add(cls));
            b.setAttribute('aria-selected', 'false');
          });

          // Active state for clicked button
          const activeColor = colorOrder[idx];
          const activeColors = scoreRangeColors[activeColor];
          activeColors.tab.split(' ').forEach(cls => btn.classList.remove(cls));
          activeColors.tabActive.split(' ').forEach(cls => btn.classList.add(cls));
          btn.setAttribute('aria-selected', 'true');

          panels.forEach((p) => {
            if (p.id === `score-panel-${target}`) {
              p.classList.remove('hidden');
            } else {
              p.classList.add('hidden');
            }
          });
        });
      });
    });
  </script>
