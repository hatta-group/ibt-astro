      <p class="text-ibt-text-light leading-relaxed mb-4">
        IB DP（ディプロマプログラム）のスコアは<strong>45点満点</strong>。ディプロマ取得には最低24点が必要で、世界平均は約30点前後です。
      </p>
      <p class="text-ibt-text-light leading-relaxed">
        スコアによって狙える大学は大きく変わります。以下のマップで、<strong>自分の目標スコアに合った大学</strong>をチェックしてみましょう。
      </p>
    </div>
  </section>

  <!-- Score Range Selector -->
  <section class="py-8 md:py-16 bg-ibt-bg" id="score-section">
    <div class="max-w-5xl mx-auto px-4">
      <!-- Score Tabs -->
      <div class="flex flex-wrap justify-center gap-2 mb-10" role="tablist">
        {scoreRanges.map((range, i) => {
          const cm = colorMap[range.color];
          return (
            <button
              role="tab"
              aria-selected={i === 0 ? 'true' : 'false'}
              aria-controls={`score-panel-${range.key}`}
              data-score-tab={range.key}
              class={`score-tab-btn flex flex-col items-center px-4 md:px-6 py-2.5 rounded-xl text-sm font-bold border-2 transition-all ${
                i === 0 ? cm.tabActive : `bg-white ${cm.tab}`
              }`}
            >
              <span class="text-base md:text-lg">{range.label}点</span>
              <span class="text-[10px] md:text-xs opacity-75">{range.sublabel}</span>
            </button>
          );
        })}
      </div>

      <!-- Score Panels -->
      {scoreRanges.map((range, i) => {
        const cm = colorMap[range.color];
        return (
          <div
            id={`score-panel-${range.key}`}
            role="tabpanel"
            class={`score-panel ${i === 0 ? '' : 'hidden'}`}
            data-color={range.color}
          >
            <!-- Description -->
            <div class={`${cm.card} ${cm.border} border rounded-2xl p-4 md:p-6 mb-8`}>
              <div class="flex items-center gap-3 mb-2">
                <span class={`${cm.badge} text-lg md:text-xl font-black px-4 py-1 rounded-full`}>{range.label}点</span>
                <span class={`${cm.text} font-bold`}>{range.sublabel}</span>
              </div>
              <p class="text-gray-700 text-sm md:text-base leading-relaxed">{range.description}</p>
            </div>

            <!-- Japan Universities -->
            <div class="mb-8">
              <h3 class="flex items-center gap-2 text-lg md:text-xl font-bold mb-4">
                <span class="text-2xl">🇯🇵</span> 日本の大学
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {range.japan.map((uni) => (
                  <div class={`bg-white rounded-xl border ${cm.border} p-5 hover:shadow-md transition-shadow`}>
                    <div class="flex items-start justify-between gap-2 mb-2">
                      <h4 class="font-bold text-gray-900">
                        {getUniSlug(uni.name) ? (
                          <a href={`/ib-universities/${getUniSlug(uni.name)}/`} class="hover:text-ibt-red transition-colors">{uni.name}</a>
                        ) : (
                          uni.name
                        )}
                      </h4>
                      {uni.hasIBAdmission && (
                        <span class="shrink-0 text-[10px] font-bold bg-green-100 text-green-700 px-2 py-0.5 rounded-full border border-green-200">IB入試あり</span>
                      )}
                    </div>
                    <div class="flex items-center gap-2 mb-2">
                      <span class={`text-xs font-bold ${cm.badge} px-2 py-0.5 rounded-full`}>目安: {uni.score}点</span>
                    </div>
                    <p class="text-gray-500 text-xs leading-relaxed">{uni.notes}</p>
                  </div>
                ))}
              </div>
            </div>

            <!-- Overseas Universities -->
            <div>
              <h3 class="flex items-center gap-2 text-lg md:text-xl font-bold mb-4">
                <span class="text-2xl">🌍</span> 海外の大学
              </h3>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {range.overseas.map((uni) => (
                  <div class={`bg-white rounded-xl border ${cm.border} p-5 hover:shadow-md transition-shadow`}>
                    <div class="flex items-start justify-between gap-2 mb-2">
                      <h4 class="font-bold text-gray-900 flex items-center gap-2">
                        <span class="text-lg">{uni.flag}</span>
                        {getUniSlug(uni.name) ? (
                          <a href={`/ib-universities/${getUniSlug(uni.name)}/`} class="hover:text-ibt-red transition-colors">{uni.name}</a>
                        ) : (
                          uni.name
                        )}
                      </h4>
                    </div>
                    <div class="flex items-center gap-2 mb-2">
                      <span class={`text-xs font-bold ${cm.badge} px-2 py-0.5 rounded-full`}>目安: {uni.score}点</span>
                    </div>
                    <p class="text-gray-500 text-xs leading-relaxed">{uni.notes}</p>
                  </div>
                ))}
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <!-- IB入試とは -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <p class="text-ibt-red font-bold text-sm tracking-widest mb-4 text-center">ABOUT IB ADMISSIONS</p>
      <h2 class="text-2xl md:text-4xl font-bold mb-6 text-center">IB入試とは？</h2>
      <div class="w-16 h-1 bg-gradient-to-r from-indigo-600 to-violet-500 mx-auto mb-8 rounded-full"></div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-ibt-bg rounded-2xl border border-ibt-border p-6">
          <h3 class="font-bold text-lg mb-3">日本のIB入試</h3>
