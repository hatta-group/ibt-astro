---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { ibSubjects } from '../../data/ib-subjects';

export function getStaticPaths() {
  return ibSubjects.map((s) => ({
    params: { slug: s.slug },
    props: { subject: s },
  }));
}

const { subject } = Astro.props;

const pageTitle = `${subject.name}（${subject.nameJa}）対策ガイド｜IBT`;
const pageDescription = `IB DP ${subject.name}（${subject.nameJa}）の対策ガイド。評価方法、勉強のコツ、よくある質問をIB卒業生講師がわかりやすく解説します。`;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": subject.tips.map((tip, i) => ({
    "@type": "Question",
    "name": `${subject.name}の勉強のコツ${i + 1}`,
    "acceptedAnswer": { "@type": "Answer", "text": tip }
  }))
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogType="article"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://ib-tutors.net/" },
        { "@type": "ListItem", "position": 2, "name": "IB科目一覧", "item": "https://ib-tutors.net/subjects/" },
        { "@type": "ListItem", "position": 3, "name": subject.name, "item": `https://ib-tutors.net/subjects/${subject.slug}/` }
      ]
    })} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>

  <!-- Hero -->
  <section class="relative overflow-hidden py-20 md:py-28" style={`background: linear-gradient(135deg, ${subject.color}ee, ${subject.color}bb)`}>
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="max-w-7xl mx-auto px-4 relative z-10">
      <nav class="text-white/85 text-sm mb-8">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/subjects/" class="hover:text-white transition-colors">IB科目一覧</a>
        <span class="mx-2">/</span>
        <span class="text-white">{subject.name}</span>
      </nav>
      <div class="flex items-center gap-3 mb-4">
        {subject.levels.map(level => (
          <span class="bg-white/20 text-white text-sm font-bold px-3 py-1 rounded-full">{level}</span>
        ))}
        <span class="text-white/70 text-sm">{subject.groupName}</span>
      </div>
      <h1 class="text-3xl md:text-5xl font-bold text-white mb-3">{subject.name}</h1>
      <p class="text-xl md:text-2xl text-white/90 font-medium">{subject.nameJa}</p>
      <p class="mt-4 text-white/80 text-lg max-w-2xl">{subject.description}</p>
    </div>
  </section>

  <div class="h-1" style={`background: linear-gradient(to right, ${subject.color}, ${subject.color}80)`}></div>

  <!-- Content -->
  <section class="py-12 md:py-20 bg-ibt-bg">
    <div class="max-w-4xl mx-auto px-4">
      <!-- Overview -->
      <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8 md:p-10 mb-8">
        <h2 class="text-xl font-bold mb-4 flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style={`background: ${subject.color}15`}>
            <svg class="w-4 h-4" style={`color: ${subject.color}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"/></svg>
          </div>
          科目概要
        </h2>
        <p class="text-ibt-text-light leading-relaxed">{subject.overview}</p>
      </div>

      <!-- Assessment -->
      <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8 md:p-10 mb-8">
        <h2 class="text-xl font-bold mb-4 flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style={`background: ${subject.color}15`}>
            <svg class="w-4 h-4" style={`color: ${subject.color}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z"/></svg>
          </div>
          評価方法
        </h2>
        <div class="space-y-3">
          {subject.assessment.map((item) => (
            <div class="flex items-start gap-3 p-3 rounded-xl bg-gray-50">
              <div class="w-2 h-2 rounded-full shrink-0 mt-2" style={`background: ${subject.color}`}></div>
              <p class="text-ibt-text-light">{item}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Topics -->
      <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8 md:p-10 mb-8">
        <h2 class="text-xl font-bold mb-4 flex items-center gap-3">
          <div class="w-8 h-8 rounded-lg flex items-center justify-center" style={`background: ${subject.color}15`}>
            <svg class="w-4 h-4" style={`color: ${subject.color}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 6.75h12M8.25 12h12m-12 5.25h12M3.75 6.75h.007v.008H3.75V6.75Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0ZM3.75 12h.007v.008H3.75V12Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Zm-.375 5.25h.007v.008H3.75v-.008Zm.375 0a.375.375 0 1 1-.75 0 .375.375 0 0 1 .75 0Z"/></svg>
          </div>
          学習トピック
        </h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {subject.topics.map((topic) => (
            <div class="flex items-center gap-3 p-3 rounded-xl border border-gray-100">
              <div class="w-6 h-6 rounded-md flex items-center justify-center shrink-0" style={`background: ${subject.color}15`}>
                <svg class="w-3 h-3" style={`color: ${subject.color}`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
              </div>
              <span class="text-sm text-ibt-text">{topic}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Tips -->
      <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8 md:p-10 mb-8" style={`border-top: 4px solid ${subject.color}`}>
        <h2 class="text-xl font-bold mb-6">IB卒業生が教える勉強のコツ</h2>
        <div class="space-y-4">
          {subject.tips.map((tip, i) => (
            <div class="flex items-start gap-4">
              <div class="shrink-0 w-8 h-8 rounded-full flex items-center justify-center text-white text-sm font-bold" style={`background: ${subject.color}`}>{i + 1}</div>
              <p class="text-ibt-text-light leading-relaxed pt-1">{tip}</p>
            </div>
          ))}
        </div>
      </div>

      <!-- Related Blog -->
      {subject.relatedBlog.length > 0 && (
        <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8 md:p-10 mb-8">
          <h2 class="text-xl font-bold mb-4">関連記事</h2>
          <div class="space-y-3">
            {subject.relatedBlog.map((article) => (
              <a href={article.url} class="flex items-center gap-3 p-4 rounded-xl border border-gray-100 hover:border-ibt-red/30 hover:bg-ibt-red-50/20 transition-all group">
                <div class="w-8 h-8 rounded-lg bg-ibt-red-50 flex items-center justify-center shrink-0">
                  <svg class="w-4 h-4 text-ibt-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
                </div>
                <span class="text-sm font-medium text-gray-700 group-hover:text-ibt-red transition-colors">{article.title}</span>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">{subject.name}の対策でお困りですか？</h2>
      <p class="text-ibt-text-light text-lg mb-8">
        IB卒業生の講師が{subject.nameJa}のマンツーマン指導を行います。60分の無料体験で実感してください。
      </p>
      <a href="/contact/" class="inline-block px-8 py-4 bg-ibt-red text-white font-bold rounded-full shadow-lg hover:bg-ibt-red-dark transition-colors cta-pulse">
        60分無料体験に申し込む
      </a>
    </div>
  </section>

  <!-- Other Subjects -->
  <section class="py-12 bg-ibt-bg">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-xl font-bold text-center mb-8">他の科目も見る</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {ibSubjects.filter(s => s.slug !== subject.slug).slice(0, 8).map((s) => (
          <a href={`/subjects/${s.slug}/`} class="group p-4 bg-white rounded-xl border border-gray-100 hover:border-gray-200 hover:shadow-sm transition-all text-center">
            <p class="text-sm font-bold group-hover:text-ibt-red transition-colors">{s.name}</p>
            <p class="text-xs text-ibt-text-light mt-1">{s.nameJa}</p>
          </a>
        ))}
      </div>
      <div class="text-center mt-6">
        <a href="/subjects/" class="text-ibt-red text-sm font-medium hover:underline">全科目を見る</a>
      </div>
    </div>
  </section>
</BaseLayout>
