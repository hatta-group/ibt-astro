---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const universities = await getCollection('universities');
  return universities.map((uni) => ({
    params: { slug: uni.data.slug },
    props: { uni },
  }));
}

const { uni } = Astro.props;
const { Content } = await render(uni);

// Get all universities for related links
const allUniversities = await getCollection('universities');
const relatedUniversities = allUniversities
  .filter((u) => u.data.region === uni.data.region && u.data.slug !== uni.data.slug)
  .slice(0, 5);

// Score range color mapping
function getScoreColor(scoreRange: string): { bg: string; text: string; border: string } {
  const nums = scoreRange.match(/\d+/g);
  if (!nums || nums.length === 0) return { bg: 'bg-gray-100', text: 'text-gray-700', border: 'border-gray-200' };
  const minScore = parseInt(nums[0], 10);
  if (minScore >= 40) return { bg: 'bg-red-100', text: 'text-red-700', border: 'border-red-200' };
  if (minScore >= 36) return { bg: 'bg-purple-100', text: 'text-purple-700', border: 'border-purple-200' };
  if (minScore >= 32) return { bg: 'bg-indigo-100', text: 'text-indigo-700', border: 'border-indigo-200' };
  if (minScore >= 28) return { bg: 'bg-blue-100', text: 'text-blue-700', border: 'border-blue-200' };
  return { bg: 'bg-emerald-100', text: 'text-emerald-700', border: 'border-emerald-200' };
}

const scoreColor = getScoreColor(uni.data.ibScoreRange);

const regionLabels: Record<string, string> = {
  japan: '日本',
  uk: 'イギリス',
  us: 'アメリカ',
  canada: 'カナダ',
  australia: 'オーストラリア',
  europe: 'ヨーロッパ',
  asia: 'アジア',
};

const regionFlags: Record<string, string> = {
  japan: '\uD83C\uDDEF\uD83C\uDDF5',
  uk: '\uD83C\uDDEC\uD83C\uDDE7',
  us: '\uD83C\uDDFA\uD83C\uDDF8',
  canada: '\uD83C\uDDE8\uD83C\uDDE6',
  australia: '\uD83C\uDDE6\uD83C\uDDFA',
  europe: '\uD83C\uDDEA\uD83C\uDDFA',
  asia: '\uD83C\uDF0F',
};

const countryFlags: Record<string, string> = {
  '\u65E5\u672C': '\uD83C\uDDEF\uD83C\uDDF5',
  '\u30A4\u30AE\u30EA\u30B9': '\uD83C\uDDEC\uD83C\uDDE7',
  '\u30A2\u30E1\u30EA\u30AB': '\uD83C\uDDFA\uD83C\uDDF8',
  '\u30AB\u30CA\u30C0': '\uD83C\uDDE8\uD83C\uDDE6',
  '\u30AA\u30FC\u30B9\u30C8\u30E9\u30EA\u30A2': '\uD83C\uDDE6\uD83C\uDDFA',
  '\u30B9\u30A4\u30B9': '\uD83C\uDDE8\uD83C\uDDED',
  '\u30D5\u30E9\u30F3\u30B9': '\uD83C\uDDEB\uD83C\uDDF7',
  '\u30AA\u30E9\u30F3\u30C0': '\uD83C\uDDF3\uD83C\uDDF1',
  '\u30B7\u30F3\u30AC\u30DD\u30FC\u30EB': '\uD83C\uDDF8\uD83C\uDDEC',
  '\u9999\u6E2F': '\uD83C\uDDED\uD83C\uDDF0',
  '\u97D3\u56FD': '\uD83C\uDDF0\uD83C\uDDF7',
  '\u4E2D\u56FD': '\uD83C\uDDE8\uD83C\uDDF3',
  '\u30C9\u30A4\u30C4': '\uD83C\uDDE9\uD83C\uDDEA',
  '\u30A4\u30BF\u30EA\u30A2': '\uD83C\uDDEE\uD83C\uDDF9',
  '\u30C7\u30F3\u30DE\u30FC\u30AF': '\uD83C\uDDE9\uD83C\uDDF0',
  '\u30D9\u30EB\u30AE\u30FC': '\uD83C\uDDE7\uD83C\uDDEA',
  '\u30B9\u30A6\u30A7\u30FC\u30C7\u30F3': '\uD83C\uDDF8\uD83C\uDDEA',
  '\u30D5\u30A3\u30F3\u30E9\u30F3\u30C9': '\uD83C\uDDEB\uD83C\uDDEE',
  '\u53F0\u6E7E': '\uD83C\uDDF9\uD83C\uDDFC',
};

const flag = countryFlags[uni.data.country] || regionFlags[uni.data.region] || '';

const uniSchema = {
  "@context": "https://schema.org",
  "@type": "EducationalOrganization",
  "name": uni.data.title,
  "alternateName": uni.data.titleEn,
  "url": uni.data.website,
  "sameAs": `https://ib-tutors.net/ib-universities/${uni.data.slug}/`
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "\u30DB\u30FC\u30E0", "item": "https://ib-tutors.net/" },
    { "@type": "ListItem", "position": 2, "name": "IB\u3067\u884C\u3051\u308B\u5927\u5B66\u30AC\u30A4\u30C9", "item": "https://ib-tutors.net/ib-universities/" },
    { "@type": "ListItem", "position": 3, "name": uni.data.title, "item": `https://ib-tutors.net/ib-universities/${uni.data.slug}/` }
  ]
};
---

<BaseLayout
  title={`${uni.data.title}のIB入試情報｜IB専門家庭教師IBT`}
  description={`${uni.data.title}(${uni.data.titleEn})のIB入試情報。IBスコア目安${uni.data.ibScoreRange}点。IB卒業生講師がマンツーマンで大学合格をサポート。`}
>
  <!-- Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/85 text-sm mb-6">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/ib-universities/" class="hover:text-white transition-colors">IBで行ける大学ガイド</a>
        <span class="mx-2">/</span>
        <span class="text-white">{uni.data.title}</span>
      </nav>
      <h1 class="text-2xl md:text-4xl font-bold text-white mb-2">
        {flag && <span class="mr-2">{flag}</span>}
        {uni.data.title}
      </h1>
      <p class="text-white/70 text-sm mb-4">{uni.data.titleEn}</p>
      <div class="flex flex-wrap items-center gap-2">
        <span class={`px-3 py-1 rounded-full text-xs font-bold ${scoreColor.bg} ${scoreColor.text}`}>
          IBスコア目安: {uni.data.ibScoreRange}点
        </span>
        <span class="px-3 py-1 rounded-full text-xs font-medium bg-white/20 text-white">
          {uni.data.country}
        </span>
        {uni.data.featured && (
          <span class="px-3 py-1 rounded-full text-xs font-bold bg-yellow-100 text-yellow-700">注目</span>
        )}
      </div>
    </div>
  </section>

  <!-- 2-Column Layout -->
  <article class="py-10 md:py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex flex-col lg:flex-row gap-8">

        <!-- Main Content -->
        <div class="flex-1 min-w-0">
          <div class="university-content bg-white rounded-2xl shadow-sm border border-gray-100 p-6 md:p-10">
            <Content />
          </div>
        </div>

        <!-- Sidebar -->
        <div class="lg:w-80 xl:w-96 shrink-0">
          <div class="lg:sticky lg:top-20 space-y-6">

            <!-- University Info Card -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
              <h3 class="font-bold text-sm text-gray-400 tracking-widest mb-4">UNIVERSITY INFO</h3>
              <dl class="space-y-3 text-sm">
                <div class="flex justify-between">
                  <dt class="text-gray-500">国</dt>
                  <dd class="font-medium text-right">{flag} {uni.data.country}</dd>
                </div>
                <div class="border-t border-gray-100"></div>
                <div class="flex justify-between">
                  <dt class="text-gray-500">地域</dt>
                  <dd class="font-medium text-right">{regionLabels[uni.data.region]}</dd>
                </div>
                <div class="border-t border-gray-100"></div>
                <div class="flex justify-between items-center">
                  <dt class="text-gray-500">IBスコア目安</dt>
                  <dd>
                    <span class={`text-xs font-bold px-2 py-0.5 rounded-full ${scoreColor.bg} ${scoreColor.text}`}>
                      {uni.data.ibScoreRange}点
                    </span>
                  </dd>
                </div>
                {uni.data.ibAdmissionType && (
                  <>
                    <div class="border-t border-gray-100"></div>
                    <div class="flex justify-between">
                      <dt class="text-gray-500">入試タイプ</dt>
                      <dd class="font-medium text-right text-xs">{uni.data.ibAdmissionType}</dd>
                    </div>
                  </>
                )}
                {uni.data.programs && uni.data.programs.length > 0 && (
                  <>
                    <div class="border-t border-gray-100"></div>
                    <div>
                      <dt class="text-gray-500 mb-2">注目プログラム</dt>
                      <dd class="flex flex-wrap gap-1">
                        {uni.data.programs.map((p: string) => (
                          <span class="text-[11px] font-medium bg-blue-50 text-blue-700 px-2 py-0.5 rounded-full">{p}</span>
                        ))}
                      </dd>
                    </div>
                  </>
                )}
                <div class="border-t border-gray-100"></div>
                <div>
                  <a
                    href={uni.data.website}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-1 text-ibt-red hover:text-ibt-red-dark font-medium text-sm transition-colors"
                  >
                    公式サイト
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
                  </a>
                </div>
              </dl>
            </div>

            <!-- IBT CTA Card -->
            <div class="bg-gradient-to-br from-ibt-red to-ibt-red-dark rounded-2xl p-6 text-white">
              <h3 class="font-bold text-lg mb-2">大学合格に向けたIB対策なら</h3>
              <p class="text-white/80 text-sm mb-5 leading-relaxed">
                IB卒業生講師がマンツーマンで指導。志望大学に合わせたスコアアップ戦略を一緒に立てましょう。
              </p>
              <a href="/contact/" class="block w-full text-center bg-white text-ibt-red font-bold py-3 rounded-full hover:bg-gray-50 transition-colors text-sm">
                60分無料体験に申し込む
              </a>
              <a href="https://lin.ee/xWMOBbI" class="block w-full text-center bg-white/15 text-white font-bold py-3 rounded-full hover:bg-white/25 transition-colors text-sm mt-3">
                LINEで相談する
              </a>
            </div>

            <!-- IBT Features -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
              <h3 class="font-bold text-sm text-gray-400 tracking-widest mb-4">IBTの特徴</h3>
              <ul class="space-y-4 text-sm">
                <li class="flex gap-3">
                  <div class="w-8 h-8 bg-ibt-red-50 rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-ibt-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347" /></svg>
                  </div>
                  <div>
                    <p class="font-bold">全員IB卒業生</p>
                    <p class="text-gray-500 text-xs">IBを経験した講師だから分かる</p>
                  </div>
                </li>
                <li class="flex gap-3">
                  <div class="w-8 h-8 bg-ibt-red-50 rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-ibt-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
                  </div>
                  <div>
                    <p class="font-bold">入会金0円</p>
                    <p class="text-gray-500 text-xs">チケット制・長期契約なし</p>
                  </div>
                </li>
                <li class="flex gap-3">
                  <div class="w-8 h-8 bg-ibt-red-50 rounded-lg flex items-center justify-center shrink-0">
                    <svg class="w-4 h-4 text-ibt-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582" /></svg>
                  </div>
                  <div>
                    <p class="font-bold">オンライン対応</p>
                    <p class="text-gray-500 text-xs">全国どこからでも受講OK</p>
                  </div>
                </li>
              </ul>
            </div>

            <!-- Related Universities -->
            {relatedUniversities.length > 0 && (
              <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
                <h3 class="font-bold text-sm text-gray-400 tracking-widest mb-4">同じ地域の大学</h3>
                <ul class="space-y-2.5 text-sm">
                  {relatedUniversities.map((r) => (
                    <li>
                      <a href={`/ib-universities/${r.data.slug}/`} class="flex items-center justify-between text-gray-600 hover:text-ibt-red transition-colors group">
                        <span class="group-hover:underline">{r.data.title}</span>
                        <span class={`text-[10px] font-bold px-2 py-0.5 rounded-full ${getScoreColor(r.data.ibScoreRange).bg} ${getScoreColor(r.data.ibScoreRange).text}`}>
                          {r.data.ibScoreRange}
                        </span>
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            )}

            <!-- Subject Pages -->
            <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
              <h3 class="font-bold text-sm text-gray-400 tracking-widest mb-4">科目別対策</h3>
              <div class="grid grid-cols-2 gap-2 text-xs">
                <a href="/subjects/math-aa/" class="p-2 rounded-lg bg-gray-50 hover:bg-ibt-red-50 text-gray-600 hover:text-ibt-red transition-colors text-center font-medium">Math AA</a>
                <a href="/subjects/english-b/" class="p-2 rounded-lg bg-gray-50 hover:bg-ibt-red-50 text-gray-600 hover:text-ibt-red transition-colors text-center font-medium">English B</a>
                <a href="/subjects/physics/" class="p-2 rounded-lg bg-gray-50 hover:bg-ibt-red-50 text-gray-600 hover:text-ibt-red transition-colors text-center font-medium">Physics</a>
                <a href="/subjects/chemistry/" class="p-2 rounded-lg bg-gray-50 hover:bg-ibt-red-50 text-gray-600 hover:text-ibt-red transition-colors text-center font-medium">Chemistry</a>
                <a href="/subjects/economics/" class="p-2 rounded-lg bg-gray-50 hover:bg-ibt-red-50 text-gray-600 hover:text-ibt-red transition-colors text-center font-medium">Economics</a>
                <a href="/subjects/tok/" class="p-2 rounded-lg bg-gray-50 hover:bg-ibt-red-50 text-gray-600 hover:text-ibt-red transition-colors text-center font-medium">TOK</a>
              </div>
              <a href="/subjects/" class="inline-flex items-center gap-1 text-ibt-red text-xs font-medium mt-3 hover:gap-2 transition-all">
                全科目を見る
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
              </a>
            </div>

            <!-- Diagnosis CTA -->
            <div class="bg-gradient-to-br from-yellow-400 to-orange-500 rounded-2xl p-6 text-white text-center">
              <h3 class="font-bold mb-2">あなたのIBerタイプは?</h3>
              <p class="text-white/80 text-sm mb-4">20問で診断できます</p>
              <a href="/iber-type-shindan/" class="block w-full bg-white text-orange-600 font-bold py-3 rounded-full hover:bg-gray-50 transition-colors text-sm">
                IBerタイプ診断を受ける
              </a>
            </div>

            <!-- Back to List -->
            <a href="/ib-universities/" class="flex items-center justify-center gap-2 w-full py-3 text-sm font-medium text-gray-500 hover:text-ibt-red bg-white rounded-2xl shadow-sm border border-gray-100 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" /></svg>
              IBで行ける大学ガイドに戻る
            </a>

          </div>
        </div>

      </div>
    </div>
  </article>

  <script type="application/ld+json" set:html={JSON.stringify(uniSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</BaseLayout>

<style is:global>
  .university-content h2 {
    font-size: 1.25rem;
    font-weight: 800;
    color: #1f2937;
    border-left: 4px solid #dc2626;
    padding-left: 0.75rem;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.4;
  }
  .university-content h2:first-child {
    margin-top: 0;
  }
  .university-content h3 {
    font-size: 1.1rem;
    font-weight: 700;
    color: #374151;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .university-content p {
    color: #4b5563;
    line-height: 1.8;
    margin-bottom: 1rem;
  }
  .university-content strong {
    color: #111827;
  }
  .university-content a {
    color: #dc2626;
    text-decoration: none;
    font-weight: 500;
  }
  .university-content a:hover {
    text-decoration: underline;
  }
  .university-content ul, .university-content ol {
    margin: 1rem 0;
    padding-left: 1.5rem;
    color: #4b5563;
  }
  .university-content li {
    margin-bottom: 0.5rem;
    line-height: 1.7;
  }
  .university-content hr {
    border: none;
    border-top: 1px solid #e5e7eb;
    margin: 2rem 0;
  }
  .university-content blockquote {
    border-left: 4px solid #e5e7eb;
    padding-left: 1rem;
    color: #6b7280;
    font-style: italic;
    margin: 1.5rem 0;
  }
</style>
