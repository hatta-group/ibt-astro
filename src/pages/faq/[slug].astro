---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { faqItems } from '../../data/faq';

export function getStaticPaths() {
  return faqItems
    .filter(item => item.detail)
    .map((item) => ({
      params: { slug: item.slug },
      props: { faq: item },
    }));
}

const { faq } = Astro.props;

// Related FAQs (exclude current)
const relatedFaqs = faqItems.filter(f => f.slug !== faq.slug).slice(0, 5);

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [{
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.detail || faq.answer,
    },
  }],
};
---

<BaseLayout
  title={`${faq.question}｜IBT よくある質問`}
  description={faq.answer}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://ib-tutors.net/" },
        { "@type": "ListItem", "position": 2, "name": "よくある質問", "item": "https://ib-tutors.net/faq/" },
        { "@type": "ListItem", "position": 3, "name": faq.question, "item": `https://ib-tutors.net/faq/${faq.slug}/` }
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/85 text-sm mb-6">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/faq/" class="hover:text-white transition-colors">よくある質問</a>
        <span class="mx-2">/</span>
        <span class="text-white">回答</span>
      </nav>
      <h1 class="text-2xl md:text-4xl font-bold text-white leading-snug">{faq.question}</h1>
    </div>
  </section>

  <!-- Answer -->
  <section class="py-16 md:py-24 bg-ibt-bg">
    <div class="max-w-3xl mx-auto px-4">
      <!-- Short Answer -->
      <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8 md:p-10 mb-8" style="border-left: 4px solid #CC2210;">
        <p class="text-ibt-red font-bold text-sm tracking-widest mb-3">回答</p>
        <p class="text-lg text-ibt-text leading-relaxed font-medium">{faq.answer}</p>
      </div>

      <!-- Detailed Answer -->
      {faq.detail && (
        <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8 md:p-10 mb-8">
          <p class="text-ibt-red font-bold text-sm tracking-widest mb-3">詳しい解説</p>
          <p class="text-ibt-text-light leading-relaxed whitespace-pre-line">{faq.detail}</p>
        </div>
      )}

      <!-- CTA -->
      <div class="bg-gradient-to-r from-ibt-gradient-start to-ibt-gradient-end rounded-2xl p-8 text-center text-white mb-8">
        <h2 class="text-xl font-bold mb-3">まだ疑問が解消されない場合は</h2>
        <p class="text-white/80 mb-6">お気軽にお問い合わせください。60分の無料体験でも詳しくご説明いたします。</p>
        <div class="flex flex-col sm:flex-row gap-3 justify-center">
          <a href="/contact/" class="inline-block bg-white text-ibt-red font-bold px-8 py-3 rounded-full hover:bg-gray-50 transition-colors">
            無料体験を申し込む
          </a>
          <a href="https://line.me/R/ti/p/@974okamx" target="_blank" rel="noopener noreferrer" class="inline-block bg-[#06C755] text-white font-bold px-8 py-3 rounded-full hover:bg-[#05b34c] transition-colors">
            LINEで相談
          </a>
        </div>
      </div>

      <!-- Related FAQs -->
      <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8 md:p-10">
        <h2 class="text-lg font-bold mb-5">他のよくある質問</h2>
        <div class="space-y-3">
          {relatedFaqs.map((item) => (
            <a href={item.detail ? `/faq/${item.slug}/` : '/faq/'} class="flex items-center gap-3 p-3 rounded-xl hover:bg-ibt-bg transition-colors group">
              <div class="w-6 h-6 rounded-full bg-ibt-red-50 flex items-center justify-center shrink-0">
                <span class="text-ibt-red text-xs font-bold">Q</span>
              </div>
              <span class="text-sm text-ibt-text group-hover:text-ibt-red transition-colors">{item.question}</span>
            </a>
          ))}
        </div>
        <a href="/faq/all/" class="inline-flex items-center gap-1 text-ibt-red text-sm font-medium mt-4 hover:gap-2 transition-all">
          全ての質問を見る
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
