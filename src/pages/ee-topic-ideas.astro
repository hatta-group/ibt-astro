<script>
  // Subject filter
  const tabs = document.querySelectorAll<HTMLButtonElement>('.subject-tab');
  const cards = document.querySelectorAll<HTMLElement>('.topic-card');
  const countEl = document.getElementById('topic-showing-count');
  const totalCount = cards.length;

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const subject = tab.dataset.subject;

      // Update active tab style
      tabs.forEach((t) => {
        t.classList.remove('bg-ibt-red', 'text-white', 'shadow-md');
        t.classList.add('bg-white', 'text-ibt-text', 'border', 'border-ibt-border');
      });
      tab.classList.remove('bg-white', 'text-ibt-text', 'border', 'border-ibt-border');
      tab.classList.add('bg-ibt-red', 'text-white', 'shadow-md');

      let visibleCount = 0;
      cards.forEach((card) => {
        if (subject === 'all' || card.dataset.subject === subject) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      if (countEl) {
        countEl.textContent = subject === 'all'
          ? `全 ${totalCount} 件を表示中`
          : `${visibleCount} 件を表示中（全 ${totalCount} 件中）`;
      }
    });
  });
</script>
