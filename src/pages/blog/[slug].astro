---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout
  title={`${post.data.title}｜IBT`}
  description={post.data.description}
  ogImage={post.data.ogImage}
>
  <!-- Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-12 md:py-16">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/70 text-sm mb-6">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/blog/" class="hover:text-white transition-colors">ブログ</a>
        <span class="mx-2">/</span>
        <span class="text-white">{post.data.title}</span>
      </nav>
      {post.data.category && (
        <span class="inline-block px-3 py-1 text-xs font-bold text-white bg-white/20 rounded-full mb-4">
          {post.data.category}
        </span>
      )}
      <h1 class="text-2xl md:text-4xl font-bold text-white">{post.data.title}</h1>
      <time class="block mt-4 text-white/70 text-sm">{post.data.date}</time>
    </div>
  </section>

  <!-- Content -->
  <article class="py-16 md:py-24 bg-white">
    <div class="max-w-3xl mx-auto px-4 prose prose-lg prose-gray
      prose-headings:font-black prose-headings:text-ibt-text
      prose-a:text-ibt-red prose-a:no-underline hover:prose-a:underline
      prose-strong:text-ibt-text
      prose-img:rounded-xl">
      <Content />
    </div>
  </article>

  <!-- CTA -->
  <section class="py-16 md:py-24 bg-ibt-bg">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">IBの学習でお困りですか？</h2>
      <p class="text-ibt-text-light text-lg mb-8">
        IB卒業生の専門家庭教師がマンツーマンでサポートします。まずは60分の無料体験をお試しください。
      </p>
      <a
        href="/contact/"
        class="inline-block px-8 py-4 bg-ibt-red text-white font-bold rounded-full shadow-lg hover:bg-ibt-red-dark transition-colors cta-pulse"
      >
        60分無料体験に申し込む
      </a>
    </div>
  </section>
</BaseLayout>
