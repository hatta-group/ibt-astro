---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(posts.map(p => p.data.category).filter(Boolean))];
  return categories.map(cat => ({
    params: { category: cat },
    props: {
      posts: posts.filter(p => p.data.category === cat)
        .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
      category: cat
    }
  }));
}

const { posts, category } = Astro.props;
const categoryNames: Record<string, string> = {
  'dp-tips': 'DP対策・勉強法',
  'ib-basics': 'IB基礎知識',
  'ib-stories': 'IB生の体験談',
  'ib-schools': 'IB認定校情報',
};
const catName = categoryNames[category] || category;

// Build category counts for navigation bar
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const categoryMap: Record<string, { label: string; color: string; bgColor: string; activeColor: string; count: number }> = {
  'dp-tips': { label: 'DP対策', color: 'text-red-700', bgColor: 'bg-red-50 border-red-200', activeColor: 'bg-red-600 text-white border-red-600', count: 0 },
  'ib-basics': { label: 'IB基礎知識', color: 'text-blue-700', bgColor: 'bg-blue-50 border-blue-200', activeColor: 'bg-blue-600 text-white border-blue-600', count: 0 },
  'ib-schools': { label: 'IB校情報', color: 'text-emerald-700', bgColor: 'bg-emerald-50 border-emerald-200', activeColor: 'bg-emerald-600 text-white border-emerald-600', count: 0 },
  'ib-stories': { label: 'IB体験談', color: 'text-amber-700', bgColor: 'bg-amber-50 border-amber-200', activeColor: 'bg-amber-600 text-white border-amber-600', count: 0 },
};
allPosts.forEach(post => {
  const cat = post.data.category;
  if (cat && categoryMap[cat]) categoryMap[cat].count++;
});
---
<BaseLayout
  title={`${catName}の記事一覧｜IB専門家庭教師IBT`}
  description={`${catName}に関するIBブログ記事一覧。IB卒業生講師が解説。`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://ib-tutors.net/" },
        { "@type": "ListItem", "position": 2, "name": "ブログ", "item": "https://ib-tutors.net/blog/" },
        { "@type": "ListItem", "position": 3, "name": catName, "item": `https://ib-tutors.net/blog/category/${category}/` }
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/85 text-sm mb-6">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/blog/" class="hover:text-white transition-colors">ブログ</a>
        <span class="mx-2">/</span>
        <span class="text-white">{catName}</span>
      </nav>
      <h1 class="text-3xl md:text-5xl font-bold text-white">{catName}</h1>
      <p class="mt-4 text-white/85 text-lg md:text-xl">{posts.length}件の記事</p>
    </div>
  </section>

  <!-- Category Filters -->
  <section class="bg-white border-b border-ibt-border sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-4 py-4">
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-xs font-bold text-ibt-text-light uppercase tracking-wider mr-2">カテゴリ</span>
        <a
          href="/blog/"
          class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium border transition-all duration-200 hover:shadow-sm bg-white border-ibt-border text-ibt-text-light hover:text-ibt-text"
        >
          すべて
          <span class="text-xs opacity-70">({allPosts.length})</span>
        </a>
        {Object.entries(categoryMap).map(([slug, cat]) => {
          const isActive = slug === category;
          return (
            <a
              href={`/blog/category/${slug}/`}
              class={`inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium border transition-all duration-200 ${isActive ? cat.activeColor + ' shadow-sm' : cat.bgColor + ' ' + cat.color + ' hover:shadow-sm'}`}
            >
              {cat.label}
              <span class={`text-xs ${isActive ? 'opacity-80' : 'opacity-70'}`}>({cat.count})</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="py-12 md:py-20 bg-ibt-bg">
    <div class="max-w-7xl mx-auto px-4">

      {posts.length === 0 ? (
        <p class="text-center text-ibt-text-light text-lg">記事を準備中です。</p>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <article class="bg-white rounded-2xl shadow-sm border border-ibt-border overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
              <a
                href={`/blog/${post.data.slug}/`}
                class="group block p-6"
              >
                <div class="flex items-center gap-3 mb-3">
                  <span class="inline-block px-3 py-1 text-xs font-bold text-ibt-red bg-ibt-red-50 rounded-full">
                    {catName}
                  </span>
                  <time class="text-xs text-ibt-text-light">{post.data.date}</time>
                </div>
                <h2 class="text-lg font-bold text-ibt-text group-hover:text-ibt-red transition-colors mb-3 line-clamp-2">
                  {post.data.title}
                </h2>
                {post.data.description && (
                  <p class="text-ibt-text-light text-sm leading-relaxed mb-4 line-clamp-3">
                    {post.data.description}
                  </p>
                )}
                <span class="text-sm font-medium text-ibt-red group-hover:translate-x-1 inline-block transition-transform duration-200">
                  続きを読む &rarr;
                </span>
              </a>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
