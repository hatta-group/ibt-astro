---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const categoryMap: Record<string, { label: string; color: string; bgColor: string; activeColor: string }> = {
  'dp-tips': { label: 'DP対策', color: 'text-red-700', bgColor: 'bg-red-50 border-red-200', activeColor: 'bg-red-600 text-white border-red-600' },
  'ib-basics': { label: 'IB基礎知識', color: 'text-blue-700', bgColor: 'bg-blue-50 border-blue-200', activeColor: 'bg-blue-600 text-white border-blue-600' },
  'ib-schools': { label: 'IB校情報', color: 'text-emerald-700', bgColor: 'bg-emerald-50 border-emerald-200', activeColor: 'bg-emerald-600 text-white border-emerald-600' },
  'ib-stories': { label: 'IB体験談', color: 'text-amber-700', bgColor: 'bg-amber-50 border-amber-200', activeColor: 'bg-amber-600 text-white border-amber-600' },
};

export const getStaticPaths: GetStaticPaths = (async () => {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const categories = [...new Set(allPosts.map(p => p.data.category).filter(Boolean))];
  return categories.map(cat => ({
    params: { slug: cat },
    props: {
      posts: allPosts
        .filter(p => p.data.category === cat)
        .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()),
      category: cat!,
    },
  }));
}) satisfies GetStaticPaths;

const { posts, category } = Astro.props;
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const catInfo = categoryMap[category] || { label: category, color: 'text-gray-700', bgColor: 'bg-gray-50 border-gray-200', activeColor: 'bg-gray-600 text-white border-gray-600' };

// Count all categories
const categoryCounts: Record<string, number> = {};
allPosts.forEach(p => {
  if (p.data.category) categoryCounts[p.data.category] = (categoryCounts[p.data.category] || 0) + 1;
});

function formatDate(dateStr: string) {
  const d = new Date(dateStr);
  return `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
}

function getCategoryStyle(cat: string | undefined) {
  if (!cat || !categoryMap[cat]) return { label: cat || '', color: 'text-gray-700', bgColor: 'bg-gray-50 border-gray-200' };
  return categoryMap[cat];
}
---

<BaseLayout
  title={`${catInfo.label}の記事一覧｜IB専門家庭教師IBT`}
  description={`${catInfo.label}に関するIB学習情報をIB専門家庭教師が発信。`}
>
  <!-- Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/85 text-sm mb-6">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/blog/" class="hover:text-white transition-colors">ブログ</a>
        <span class="mx-2">/</span>
        <span class="text-white">{catInfo.label}</span>
      </nav>
      <h1 class="text-3xl md:text-5xl font-bold text-white">{catInfo.label}</h1>
      <p class="mt-4 text-white/85 text-lg md:text-xl">{posts.length} 件の記事</p>
    </div>
  </section>

  <!-- Category Filters -->
  <section class="bg-white border-b border-ibt-border sticky top-0 z-10">
    <div class="max-w-7xl mx-auto px-4 py-4">
      <div class="flex flex-wrap items-center gap-2">
        <span class="text-xs font-bold text-ibt-text-light uppercase tracking-wider mr-2">カテゴリ</span>
        <a
          href="/blog/"
          class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium border transition-all duration-200 bg-white text-ibt-text border-ibt-border hover:shadow-sm"
        >
          すべて
          <span class="text-xs opacity-70">({allPosts.length})</span>
        </a>
        {Object.entries(categoryMap).map(([slug, cat]) => {
          const isActive = slug === category;
          return (
            <a
              href={`/blog/category/${slug}/`}
              class={`inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium border transition-all duration-200 ${isActive ? cat.activeColor + ' shadow-sm' : cat.bgColor + ' ' + cat.color + ' hover:shadow-sm'}`}
            >
              {cat.label}
              <span class="text-xs opacity-70">({categoryCounts[slug] || 0})</span>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="py-12 md:py-20 bg-ibt-bg">
    <div class="max-w-7xl mx-auto px-4">
      {posts.length === 0 ? (
        <p class="text-center text-ibt-text-light text-lg py-20">このカテゴリの記事はまだありません。</p>
      ) : (
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8">
          {posts.map((post) => {
            const style = getCategoryStyle(post.data.category);
            return (
              <a
                href={`/blog/${post.data.slug}/`}
                class="group block"
              >
                <article class="bg-white rounded-2xl shadow-sm border border-ibt-border overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1 h-full flex flex-col">
                  <div class="h-1 bg-gradient-to-r from-ibt-gradient-start to-ibt-gradient-end opacity-0 group-hover:opacity-100 transition-opacity duration-300" />
                  <div class="p-6 flex flex-col flex-1">
                    <div class="flex items-center justify-between gap-2 mb-4">
                      {post.data.category && (
                        <span class={`inline-block px-2.5 py-0.5 text-xs font-bold rounded-full border ${style.bgColor} ${style.color}`}>
                          {style.label}
                        </span>
                      )}
                      <time class="text-xs text-ibt-text-light whitespace-nowrap">
                        {formatDate(post.data.date)}
                      </time>
                    </div>
                    <h2 class="text-lg font-bold text-ibt-text group-hover:text-ibt-red transition-colors mb-3 leading-snug line-clamp-2">
                      {post.data.title}
                    </h2>
                    {post.data.description && (
                      <p class="text-ibt-text-light text-sm leading-relaxed mb-4 line-clamp-3 flex-1">
                        {post.data.description}
                      </p>
                    )}
                    <span class="inline-flex items-center text-ibt-red font-medium text-sm mt-auto group-hover:gap-1.5 gap-1 transition-all duration-200">
                      続きを読む
                      <svg class="w-3.5 h-3.5 transition-transform duration-200 group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                      </svg>
                    </span>
                  </div>
                </article>
              </a>
            );
          })}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
