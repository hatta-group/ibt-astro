---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export const getStaticPaths: GetStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection('blog', ({ data }) => !data.draft);
  const sorted = allPosts.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
  );
  return paginate(sorted, { pageSize: 24 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const pageTitle = page.currentPage === 1
  ? "ブログ｜IB専門家庭教師IBT"
  : `ブログ（${page.currentPage}ページ目）｜IB専門家庭教師IBT`;
---

<BaseLayout
  title={pageTitle}
  description="IB（国際バカロレア）に関する最新情報、学習のコツ、TOK・EE対策、科目別勉強法などをIB専門家庭教師が発信。"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://ib-tutors.net/" },
        { "@type": "ListItem", "position": 2, "name": "ブログ", "item": "https://ib-tutors.net/blog/" }
      ]
    })} />
  </Fragment>

  <!-- Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/70 text-sm mb-6">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <span class="text-white">ブログ</span>
      </nav>
      <h1 class="text-3xl md:text-5xl font-bold text-white">ブログ</h1>
      <p class="mt-4 text-white/85 text-lg md:text-xl">IB学習に役立つ情報をお届けします</p>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="py-16 md:py-24 bg-ibt-bg">
    <div class="max-w-7xl mx-auto px-4">
      {page.data.length === 0 ? (
        <p class="text-center text-ibt-text-light text-lg">記事を準備中です。</p>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {page.data.map((post) => (
            <article class="bg-white rounded-2xl shadow-sm border border-ibt-border overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
              <a
                href={`/blog/${post.data.slug}/`}
                class="group block p-6"
              >
                {post.data.category && (
                  <span class="inline-block px-3 py-1 text-xs font-bold text-ibt-red bg-ibt-red-50 rounded-full mb-3">
                    {post.data.category}
                  </span>
                )}
                <h2 class="text-lg font-bold text-ibt-text group-hover:text-ibt-red transition-colors mb-3 line-clamp-2">
                  {post.data.title}
                </h2>
                {post.data.description && (
                  <p class="text-ibt-text-light text-sm leading-relaxed mb-4 line-clamp-3">
                    {post.data.description}
                  </p>
                )}
                <time class="text-xs text-ibt-text-light">{post.data.date}</time>
              </a>
            </article>
          ))}
        </div>
      )}

      {page.lastPage > 1 && (
        <nav class="flex justify-center items-center gap-3 mt-12" aria-label="ページネーション">
          {page.url.prev && (
            <a href={page.url.prev} class="px-4 py-2 border border-ibt-border rounded-lg hover:bg-ibt-red hover:text-white hover:border-ibt-red transition-colors text-sm font-medium">前へ</a>
          )}
          <span class="text-ibt-text-light text-sm">{page.currentPage} / {page.lastPage}</span>
          {page.url.next && (
            <a href={page.url.next} class="px-4 py-2 border border-ibt-border rounded-lg hover:bg-ibt-red hover:text-white hover:border-ibt-red transition-colors text-sm font-medium">次へ</a>
          )}
        </nav>
      )}
    </div>
  </section>
</BaseLayout>
