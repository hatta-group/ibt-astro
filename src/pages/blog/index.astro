---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<BaseLayout
  title="ブログ｜IB専門家庭教師IBT"
  description="IB（国際バカロレア）に関する最新情報、学習のコツ、TOK・EE対策、科目別勉強法などをIB専門家庭教師が発信。"
>
  <!-- Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-16 md:py-24">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/70 text-sm mb-6">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <span class="text-white">ブログ</span>
      </nav>
      <h1 class="text-3xl md:text-5xl font-bold text-white">ブログ</h1>
      <p class="mt-4 text-white/85 text-lg md:text-xl">IB学習に役立つ情報をお届けします</p>
    </div>
  </section>

  <!-- Posts Grid -->
  <section class="py-16 md:py-24 bg-ibt-bg">
    <div class="max-w-7xl mx-auto px-4">
      {posts.length === 0 ? (
        <p class="text-center text-ibt-text-light text-lg">記事を準備中です。</p>
      ) : (
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {posts.map((post) => (
            <a
              href={`/blog/${post.data.slug}/`}
              class="group bg-white rounded-2xl shadow-sm border border-ibt-border overflow-hidden hover:shadow-lg transition-all duration-300 hover:-translate-y-1"
            >
              <div class="p-6">
                {post.data.category && (
                  <span class="inline-block px-3 py-1 text-xs font-bold text-ibt-red bg-ibt-red-50 rounded-full mb-3">
                    {post.data.category}
                  </span>
                )}
                <h2 class="text-lg font-bold text-ibt-text group-hover:text-ibt-red transition-colors mb-3 line-clamp-2">
                  {post.data.title}
                </h2>
                {post.data.description && (
                  <p class="text-ibt-text-light text-sm leading-relaxed mb-4 line-clamp-3">
                    {post.data.description}
                  </p>
                )}
                <time class="text-xs text-ibt-text-light">{post.data.date}</time>
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
