---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { iberTypes } from '../../data/iber-types';

export function getStaticPaths() {
  return iberTypes.map((t) => ({
    params: { type: t.id },
    props: { typeData: t },
  }));
}

const { typeData } = Astro.props;
const typeColor = typeData.color;

const pageTitle = `IBerタイプ診断結果: ${typeData.name}（${typeData.nameJa}）｜IBT`;
const pageDescription = `IBerタイプ診断の結果、あなたは「${typeData.name}（${typeData.nameJa}）」タイプ！${typeData.description} 自分も診断してみよう。`;

const resultSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": pageTitle,
  "description": pageDescription,
  "url": `https://ib-tutors.net/iber-type-shindan/${typeData.id}/`,
  "mainEntity": {
    "@type": "Quiz",
    "name": "IBerタイプ診断",
    "about": "IB Learner Profileに基づく学習タイプ診断"
  }
};
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  ogImage={`/images/iber-types/share/${typeData.id}.jpg`}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(resultSchema)} />
    <link rel="canonical" href={`https://ib-tutors.net/iber-type-shindan/${typeData.id}/`} />
  </Fragment>

  <!-- Result Hero -->
  <section class="relative overflow-hidden py-20 md:py-28" style={`background: linear-gradient(135deg, ${typeColor}ee, ${typeColor}bb)`}>
    <div class="absolute inset-0 opacity-10" style="background: radial-gradient(circle at 80% 20%, rgba(255,255,255,0.4), transparent 60%);"></div>
    <div class="max-w-7xl mx-auto px-4 relative z-10">
      <nav class="text-white/85 text-sm mb-8">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <a href="/iber-type-shindan/" class="hover:text-white transition-colors">IBerタイプ診断</a>
        <span class="mx-2">/</span>
        <span class="text-white">結果: {typeData.name}</span>
      </nav>
      <div class="flex flex-col md:flex-row items-center gap-8">
        <div class="relative w-48 h-48 md:w-56 md:h-56 shrink-0">
          <div class="absolute inset-[-12px] rounded-full bg-white/90 shadow-lg"></div>
          <img
            src={`/images/iber-types/${typeData.id}.webp`}
            alt={`IBerタイプ「${typeData.name}」のキャラクター`}
            class="w-full h-full object-contain drop-shadow-2xl relative z-10"
          />
        </div>
        <div class="text-center md:text-left">
          <p class="text-white/70 text-sm font-bold tracking-widest mb-2">YOUR TYPE</p>
          <h1 class="text-4xl md:text-5xl font-black text-white mb-2">{typeData.name}</h1>
          <p class="text-xl md:text-2xl font-bold text-white/90 mb-4">{typeData.nameJa}</p>
          <p class="text-white/80 leading-relaxed max-w-lg">{typeData.description}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA: Try the quiz yourself -->
  <section class="py-12 md:py-16 bg-ibt-bg">
    <div class="max-w-3xl mx-auto px-4">
      <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8 md:p-12 text-center">
        <h2 class="text-2xl md:text-3xl font-bold mb-4">自分のタイプを診断してみよう</h2>
        <p class="text-ibt-text-light mb-6">20問の質問に答えるだけで、あなたのIBerタイプがわかります。約3分で完了。</p>
        <a
          href="/iber-type-shindan/"
          class="inline-flex items-center gap-2 bg-gradient-to-r from-ibt-gradient-start to-ibt-gradient-end text-white font-bold px-10 py-5 rounded-full hover:shadow-xl hover:scale-[1.03] transition-all text-lg cta-pulse"
        >
          診断を始める
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Type Details Link -->
  <section class="py-12 bg-white">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <h2 class="text-xl md:text-2xl font-bold mb-4">{typeData.name}タイプの詳細を見る</h2>
      <p class="text-ibt-text-light mb-6">性格・強み・課題・得意科目・相性タイプなど、詳しい分析結果をチェック。</p>
      <a
        href={`/iber-type/${typeData.id}/`}
        class="inline-flex items-center gap-2 px-8 py-4 border-2 font-bold rounded-full hover:text-white transition-colors"
        style={`border-color: ${typeColor}; color: ${typeColor};`}
      >
        {typeData.name}の詳細ページへ
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
      </a>
    </div>
  </section>

  <!-- Share -->
  <section class="py-12 bg-ibt-bg">
    <div class="max-w-3xl mx-auto px-4">
      <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-6 text-center">
        <p class="font-bold text-base mb-1">友達にもシェアしよう!</p>
        <p class="text-sm text-ibt-text-light mb-4">この結果をシェアする</p>
        <div class="flex flex-wrap gap-3 justify-center">
          <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(`IBerタイプ診断で「${typeData.name}（${typeData.nameJa}）」だった!\n${typeData.description}\nあなたは何タイプ?`)}&url=${encodeURIComponent(`https://ib-tutors.net/iber-type-shindan/${typeData.id}/`)}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-5 py-2.5 bg-black text-white rounded-full text-sm font-bold hover:bg-gray-800 transition-colors">
            <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            Xでシェア
          </a>
          <a href={`https://social-plugins.line.me/lineit/share?url=${encodeURIComponent(`https://ib-tutors.net/iber-type-shindan/${typeData.id}/`)}&text=${encodeURIComponent(`IBerタイプ診断やってみたら「${typeData.name}（${typeData.nameJa}）」だった! あなたもやってみて!`)}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-5 py-2.5 bg-[#06C755] text-white rounded-full text-sm font-bold hover:opacity-90 transition-opacity">
            LINE
          </a>
          <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`https://ib-tutors.net/iber-type-shindan/${typeData.id}/`)}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 px-5 py-2.5 bg-[#1877F2] text-white rounded-full text-sm font-bold hover:opacity-90 transition-opacity">
            Facebook
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Other Types -->
  <section class="py-12 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <h2 class="text-xl md:text-2xl font-bold text-center mb-8">他のIBerタイプも見る</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
        {iberTypes.filter(t => t.id !== typeData.id).map((t) => (
          <a
            href={`/iber-type/${t.id}/`}
            class="group flex flex-col items-center p-4 rounded-xl hover:bg-ibt-bg transition-colors text-center"
          >
            <div class="w-14 h-14 mb-2">
              <img
                src={`/images/iber-types/${t.id}.webp`}
                alt={`${t.name} - ${t.nameJa}`}
                class="w-full h-full object-contain"
                loading="lazy"
              />
            </div>
            <span class="text-sm font-bold group-hover:text-ibt-red transition-colors">{t.name}</span>
            <span class="text-xs text-ibt-text-light">{t.nameJa}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- IBT CTA -->
  <section class="py-16 md:py-24 bg-gradient-to-br from-gray-900 to-gray-800">
    <div class="max-w-3xl mx-auto px-4 text-center">
      <p class="text-white/60 text-sm font-bold tracking-widest mb-3">FOR {typeData.name.toUpperCase()} TYPE</p>
      <h2 class="text-2xl md:text-3xl font-bold text-white mb-4">
        {typeData.name}タイプのあなたに合った学び方、一緒に見つけませんか？
      </h2>
      <p class="text-white/70 text-lg mb-8 leading-relaxed">
        IBTの講師は全員IB卒業生。あなたの強みを活かした学習プランを、60分の無料体験でご提案します。入会義務は一切ありません。
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/contact/"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-ibt-gradient-start to-ibt-gradient-end text-white font-bold rounded-full shadow-lg hover:shadow-xl hover:scale-[1.03] transition-all cta-pulse"
        >
          60分無料体験に申し込む
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
        </a>
        <a
          href="https://line.me/R/ti/p/@974okamx"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-2 px-8 py-4 bg-[#06C755] text-white font-bold rounded-full hover:bg-[#05b34c] transition-colors"
        >
          <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
          LINEで気軽に相談
        </a>
      </div>
      <p class="text-white/40 text-xs mt-6">入会金0円 / チケット制で長期契約なし / オンライン対応</p>
    </div>
  </section>
</BaseLayout>
