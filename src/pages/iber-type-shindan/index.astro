        btn.setAttribute('role', 'radio');
        btn.setAttribute('aria-checked', 'false');
        btn.setAttribute('aria-label', `選択肢${String.fromCharCode(65 + i)}: ${answer.text}`);
        btn.innerHTML = `<span class="flex items-center gap-3"><span class="answer-letter w-8 h-8 rounded-full border-2 border-ibt-border group-hover:border-ibt-red group-hover:bg-ibt-red group-hover:text-white flex items-center justify-center text-sm font-bold shrink-0 transition-all" aria-hidden="true">${String.fromCharCode(65 + i)}</span><span class="leading-relaxed">${answer.text}</span></span>`;
        btn.addEventListener('click', () => selectAnswer(answer.types, answer.subTypes || [], btn));
        answersDiv.appendChild(btn);
      });
    }

    function selectAnswer(typeIds, subTypeIds, selectedBtn) {
