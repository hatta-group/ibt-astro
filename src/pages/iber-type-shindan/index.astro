      details.bestSubjects.forEach(function(s) { subjectsHtml += '<span class="px-4 py-2 rounded-full text-sm font-bold" style="background-color:' + winner.color + '15;color:' + winner.color + '">' + s + '</span>'; });
      subjectsHtml += '</div>';
      subjectsDiv.innerHTML = subjectsHtml;
      studyDiv.parentNode.insertBefore(subjectsDiv, studyDiv.nextSibling);

      // Add compatible types
      var compatDiv = document.createElement('div');
      compatDiv.className = 'bg-white rounded-2xl shadow-sm border border-ibt-border p-6 md:p-8 mb-8';
      compatDiv.innerHTML = '<div class="flex items-center gap-3 mb-4"><div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background-color:' + winner.color + '20"><svg class="w-5 h-5" style="color:' + winner.color + '" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/></svg></div><h3 class="font-bold text-lg">相性の良いタイプ</h3></div><p class="text-ibt-text-light">' + details.compatibleTypes.join('、') + ' と相性が良いです。一緒にグループワークをすると互いの強みを引き出せます。</p>';
