---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { iberTypes } from '../../data/iber-types';
---

<BaseLayout
  title="IBerタイプ診断｜あなたのIBerタイプは？｜IBT"
  description="あなたのIBerタイプは？たった20問でIB Learner's Profileの10タイプを診断。試験・EE・CASなどIB生ならではの質問で強みと課題を発見。"
  ogImage="/images/iber-types/iber-shindan-banner.jpg"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://ib-tutors.net/" },
        { "@type": "ListItem", "position": 2, "name": "IBerタイプ診断", "item": "https://ib-tutors.net/iber-type-shindan/" }
      ]
    })} />
  </Fragment>

  <!-- Hero - Visual & Exciting -->
  <section class="relative overflow-hidden bg-gradient-to-br from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-20 md:py-28">
    <!-- Decorative background -->
    <div class="absolute inset-0 opacity-[0.06]" style="background-image: url('data:image/svg+xml,%3Csvg width=&quot;60&quot; height=&quot;60&quot; viewBox=&quot;0 0 60 60&quot; xmlns=&quot;http://www.w3.org/2000/svg&quot;%3E%3Cg fill=&quot;none&quot; fill-rule=&quot;evenodd&quot;%3E%3Cg fill=&quot;%23ffffff&quot; fill-opacity=&quot;1&quot;%3E%3Cpath d=&quot;M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z&quot;/%3E%3C/g%3E%3C/g%3E%3C/svg%3E');"></div>
    <div class="absolute top-0 right-0 w-96 h-96 bg-white/5 rounded-full -translate-y-1/2 translate-x-1/3 blur-3xl"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-white/5 rounded-full translate-y-1/2 -translate-x-1/3 blur-2xl"></div>

    <div class="max-w-7xl mx-auto px-4 relative z-10">
      <nav class="text-white/85 text-sm mb-8" aria-label="パンくずリスト">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">/</span>
        <span class="text-white">IBerタイプ診断</span>
      </nav>

      <div class="flex flex-col items-center text-center">
        <!-- Text -->
        <div class="max-w-2xl">
          <div class="inline-flex items-center gap-2 bg-white/15 backdrop-blur-sm px-4 py-2 rounded-full mb-6">
            <span class="w-2 h-2 bg-yellow-300 rounded-full animate-pulse"></span>
            <span class="text-white/90 text-sm font-bold">10タイプから診断</span>
          </div>
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-black text-white leading-tight">
            あなたの<br /><span class="text-yellow-300">IBerタイプ</span>は？
          </h1>
          <p class="mt-5 text-white/85 text-lg md:text-xl leading-relaxed">
            たった20問であなたの学習スタイルを診断！<br class="hidden md:block" />
            IB Learner Profileの10タイプから、<br class="hidden md:block" />
            あなたの強み・課題・相性がわかる。
          </p>
          <div class="mt-4 flex flex-wrap gap-3 justify-center text-white/70 text-sm">
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
              約3分
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.879 7.519c1.171-1.025 3.071-1.025 4.242 0 1.172 1.025 1.172 2.687 0 3.712-.203.179-.43.326-.67.442-.745.361-1.45.999-1.45 1.827v.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 5.25h.008v.008H12v-.008Z"/></svg>
              全20問
            </span>
            <span class="flex items-center gap-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 1 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 0 0-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 0 1-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 0 0 3 15h-.75M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/></svg>
              完全無料
            </span>
          </div>
        </div>
    </div>

    </div>
  </section>

  <!-- Quiz -->
  <section class="py-16 md:py-24 bg-ibt-bg">
    <div class="max-w-3xl mx-auto px-4">
      <!-- Start Screen -->
      <div id="quiz-start" class="text-center">
        <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-10 md:p-14">
          <h2 class="text-2xl md:text-3xl font-bold mb-3">診断スタート!</h2>
          <p class="text-ibt-text-light mb-2">20問の質問に答えるだけで</p>
          <p class="text-ibt-text-light mb-6">あなたのIBerタイプがわかります。</p>

          <!-- What you'll discover -->
          <div class="grid grid-cols-2 gap-3 max-w-sm mx-auto mb-8 text-left">
            <div class="flex items-center gap-2 bg-ibt-bg rounded-lg px-3 py-2.5">
              <span class="text-lg">💪</span>
              <span class="text-sm font-medium text-ibt-text">あなたの強み</span>
            </div>
            <div class="flex items-center gap-2 bg-ibt-bg rounded-lg px-3 py-2.5">
              <span class="text-lg">📚</span>
              <span class="text-sm font-medium text-ibt-text">得意科目</span>
            </div>
            <div class="flex items-center gap-2 bg-ibt-bg rounded-lg px-3 py-2.5">
              <span class="text-lg">✏️</span>
              <span class="text-sm font-medium text-ibt-text">学習スタイル</span>
            </div>
            <div class="flex items-center gap-2 bg-ibt-bg rounded-lg px-3 py-2.5">
              <span class="text-lg">🤝</span>
              <span class="text-sm font-medium text-ibt-text">相性タイプ</span>
            </div>
          </div>

          <button
            id="start-btn"
            class="inline-flex items-center gap-2 bg-gradient-to-r from-ibt-gradient-start to-ibt-gradient-end text-white font-bold px-10 py-5 rounded-full hover:shadow-xl hover:scale-[1.03] transition-all text-lg cursor-pointer cta-pulse"
          >
            診断を始める
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg>
          </button>
          <p class="mt-5 text-xs text-ibt-text-light">IB生はもちろん、IB以外の方もOK!</p>
          <p class="mt-2">
            <a href="/ib-learner-profile/" class="text-sm text-ibt-text-light hover:text-ibt-red transition-colors underline underline-offset-4">
              IB Learner Profileとは？ →
            </a>
          </p>
        </div>

        <!-- Banner Image -->
        <div class="mt-8">
          <img
            src="/images/iber-types/iber-shindan-banner.jpg"
            alt="IBerタイプ診断 - 10タイプのキャラクター集合イラスト"
            class="w-full rounded-2xl shadow-lg"
            loading="eager"
          />
        </div>
      </div>

      <!-- Quiz Container -->
      <div id="quiz-container" class="hidden" aria-live="polite">
        <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-8 md:p-12">
          <!-- Progress -->
          <div class="mb-8">
            <div class="flex justify-between items-center text-sm text-ibt-text-light mb-2">
              <span>質問 <span id="current-q">1</span> / 20</span>
              <span id="remaining-q" class="font-bold text-ibt-red">あと20問</span>
            </div>
            <div class="w-full bg-ibt-border rounded-full h-2">
              <div id="progress-bar" class="bg-gradient-to-r from-ibt-gradient-start to-ibt-gradient-end h-2 rounded-full transition-all duration-300" style="width: 0%" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
            </div>
          </div>

          <!-- Question -->
          <h3 id="question-text" class="text-xl md:text-2xl font-bold mb-8 leading-relaxed"></h3>

          <!-- Answer Choices -->
          <div id="answers" class="space-y-3" role="radiogroup" aria-label="回答選択肢"></div>

          <!-- Back Button -->
          <div class="mt-6">
            <button id="back-btn" class="hidden inline-flex items-center gap-2 text-ibt-text-light text-sm font-medium hover:text-ibt-red transition-colors cursor-pointer">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/></svg>
              前の質問に戻る
            </button>
          </div>
        </div>
      </div>

      <!-- Result -->
      <div id="quiz-result" class="hidden">
        <!-- Hero Result -->
        <div id="result-header" class="relative rounded-3xl overflow-hidden mb-8" style="min-height: 380px;">
          <div class="absolute inset-0 opacity-15" style="background: radial-gradient(circle at 70% 30%, rgba(255,255,255,0.5), transparent 60%);"></div>
          <div class="relative z-10 flex flex-col md:flex-row items-center justify-center gap-6 px-8 py-12 md:py-16">
            <!-- Character Image - BIG -->
            <div class="relative w-48 h-48 md:w-64 md:h-64 shrink-0">
              <div class="absolute inset-[-12px] rounded-full bg-white/90 shadow-lg"></div>
              <img id="result-image" src="" alt="あなたのIBerタイプ診断結果" class="w-full h-full object-contain drop-shadow-2xl relative z-10" />
            </div>
            <!-- Type Info -->
            <div class="text-center md:text-left">
              <p class="text-white/70 text-sm font-bold tracking-widest mb-2">YOUR TYPE</p>
              <div id="result-badge" class="text-4xl md:text-5xl font-black text-white mb-2"></div>
              <p id="result-name-ja" class="text-xl md:text-2xl font-bold text-white/90 mb-2"></p>
              <p id="result-stat" class="text-white/70 text-sm font-bold mb-4"></p>
              <p id="result-desc" class="text-white/80 leading-relaxed max-w-md text-sm md:text-base"></p>
            </div>
          </div>
        </div>

        <!-- Share -->
        <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-6 text-center mb-8">
          <p class="font-bold text-base mb-1">友達にもやってみてもらおう!</p>
          <p class="text-sm text-ibt-text-light mb-4">結果をシェアする</p>
          <div class="flex flex-wrap gap-3 justify-center">
            <button id="share-x" class="flex items-center gap-2 px-5 py-2.5 bg-black text-white rounded-full text-sm font-bold hover:bg-gray-800 transition-colors cursor-pointer" aria-label="Xでシェア">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              Xでシェア
            </button>
            <button id="share-line" class="flex items-center gap-2 px-5 py-2.5 bg-[#06C755] text-white rounded-full text-sm font-bold hover:opacity-90 transition-opacity cursor-pointer" aria-label="LINEでシェア">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
              LINEでシェア
            </button>
            <button id="share-fb" class="flex items-center gap-2 px-5 py-2.5 bg-[#1877F2] text-white rounded-full text-sm font-bold hover:opacity-90 transition-opacity cursor-pointer" aria-label="Facebookでシェア">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              Facebookでシェア
            </button>
            <button id="share-ig" class="flex items-center gap-2 px-5 py-2.5 bg-gradient-to-r from-[#F58529] via-[#DD2A7B] to-[#8134AF] text-white rounded-full text-sm font-bold hover:opacity-90 transition-opacity cursor-pointer" aria-label="Instagramでシェア">
              <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              画像を保存
            </button>
          </div>
          <!-- Instagram share image preview -->
          <div id="ig-share-preview" class="hidden mt-6">
            <p class="text-sm text-ibt-text-light mb-3">この画像を保存して、Instagramのストーリーズやフィードに投稿しよう!</p>
            <img id="ig-share-image" src="" alt="IBerタイプ診断結果シェア画像" class="mx-auto rounded-xl shadow-lg max-w-[320px] w-full" />
            <a id="ig-download-btn" href="" download="" class="inline-flex items-center gap-2 mt-4 px-6 py-3 bg-gradient-to-r from-[#F58529] via-[#DD2A7B] to-[#8134AF] text-white rounded-full text-sm font-bold hover:opacity-90 transition-opacity">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
              画像をダウンロード
            </a>
          </div>
        </div>

        <!-- Strengths & Challenges Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
          <!-- Strengths -->
          <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-6 md:p-8">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 rounded-xl bg-emerald-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
              </div>
              <h3 class="font-bold text-lg">あなたの強み</h3>
            </div>
            <ul id="result-strengths" class="space-y-3"></ul>
          </div>
          <!-- Challenges -->
          <div class="bg-white rounded-2xl shadow-sm border border-ibt-border p-6 md:p-8">
            <div class="flex items-center gap-3 mb-5">
              <div class="w-10 h-10 rounded-xl bg-amber-100 flex items-center justify-center">
                <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126ZM12 15.75h.007v.008H12v-.008Z"/></svg>
              </div>
              <h3 class="font-bold text-lg">IBでの課題</h3>
            </div>
            <ul id="result-challenges" class="space-y-3"></ul>
          </div>
        </div>

        <!-- Detailed Analysis -->
        <div id="result-analysis" class="bg-white rounded-2xl shadow-sm border border-ibt-border p-6 md:p-8 mb-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-10 h-10 rounded-xl bg-blue-100 flex items-center justify-center">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 0 0-2.455 2.456Z"/></svg>
            </div>
            <h3 class="font-bold text-lg">あなただけの詳細分析</h3>
          </div>
          <p id="result-analysis-text" class="text-ibt-text-light leading-relaxed"></p>
        </div>

        <!-- Score Distribution -->
        <div id="score-distribution-section" class="bg-white rounded-2xl shadow-sm border border-ibt-border p-6 md:p-8 mb-8">
          <h3 class="font-bold text-lg mb-5 text-center">あなたのタイプ分布</h3>
          <div id="result-scores" class="space-y-3"></div>
        </div>

        <!-- Direct Link CTA (shown when accessed via ?result= parameter) -->
        <div id="direct-link-cta" class="hidden bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end rounded-2xl p-8 md:p-10 text-center mb-8">
          <h3 class="text-xl md:text-2xl font-bold text-white mb-3">自分も診断してみよう!</h3>
          <p class="text-white/80 mb-6">20問の質問に答えるだけで、あなたのIBerタイプがわかります。</p>
          <button id="direct-start-btn" class="inline-block bg-white text-ibt-red font-bold px-8 py-4 rounded-full hover:bg-ibt-red-light transition-colors text-lg shadow-lg cursor-pointer">
            診断を始める
          </button>
        </div>

        <!-- Type-matched CTA -->
        <div id="type-matched-cta" class="bg-gradient-to-br from-ibt-red to-ibt-red-dark rounded-2xl p-8 md:p-10 text-center mb-8">
          <p class="text-white/70 text-sm font-bold tracking-widest mb-2">YOUR NEXT STEP</p>
          <h3 id="type-cta-title" class="text-xl md:text-2xl font-bold text-white mb-3">あなたのタイプに合った学習法を体験しよう</h3>
