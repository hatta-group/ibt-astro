      var analysisDiv = document.getElementById('result-analysis');

      // Add personality summary
      var personalityDiv = document.createElement('div');
      personalityDiv.className = 'bg-white rounded-2xl shadow-sm border border-ibt-border p-6 md:p-8 mb-8';
      personalityDiv.innerHTML = '<div class="flex items-center gap-3 mb-4"><div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background-color:' + winner.color + '20"><svg class="w-5 h-5" style="color:' + winner.color + '" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0"/></svg></div><h3 class="font-bold text-lg">あなたの性格</h3></div><p class="text-ibt-text-light leading-relaxed">' + details.personality + '</p>';
