        'caring': [
          { title: 'IB DP1年目の「あるある失敗」を家庭教師が本音で語ります', url: '/blog/ib-dp-year1-common-mistakes/' },
          { title: 'IB家庭教師はいつから始める？ベストタイミングの見極め方', url: '/blog/ib-tutor-best-timing/' },
        ],
        'risk-taker': [
          { title: 'IB生が大学受験で有利になる5つの理由', url: '/blog/ib-university-admission-advantages/' },
          { title: 'Extended Essay（EE）とは？ゼロからわかりやすく解説', url: '/blog/ib-ee-explained/' },
        ],
        'balanced': [
          { title: '新学期直前！IB DP1年生がやっておくべき準備リスト', url: '/blog/ib-dp14-new-semester-preparation/' },
          { title: 'IB家庭教師・日本語サポートで変わる｜成績が伸び悩んだときに', url: '/blog/ib-tutoring-japanese-support-parental-guidance/' },
        ],
        'reflective': [
          { title: 'Extended Essay（EE）とは？ゼロからわかりやすく解説', url: '/blog/ib-ee-explained/' },
          { title: 'TOKで高得点を取るための実践テクニック', url: '/blog/tok-high-score-tips/' },
        ],
      };
      const articles = articlesByType[winnerId] || [];
      const recList = document.getElementById('recommended-list');
      recList.innerHTML = articles.map(a =>
        `<a href="${a.url}" class="flex items-center gap-3 p-4 rounded-xl border border-gray-100 hover:border-ibt-red/30 hover:bg-ibt-red-50/30 transition-all group">
          <div class="w-8 h-8 rounded-lg bg-ibt-red-50 flex items-center justify-center shrink-0">
            <svg class="w-4 h-4 text-ibt-red" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
          </div>
          <span class="text-sm font-medium text-gray-700 group-hover:text-ibt-red transition-colors">${a.title}</span>
        </a>`
      ).join('');

      resultContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    function resetQuiz() {
      currentQuestion = 0;
      types.forEach((t) => (scores[t.id] = 0));
      answerHistory.length = 0;
      isDirectResult = false;
      // Remove dynamically added sections
      var dynamicSections = resultContainer.querySelectorAll('.bg-white.rounded-2xl.shadow-sm.border.border-ibt-border.p-6.md\\:p-8.mb-8:not(#result-analysis):not(#score-distribution-section):not(.grid *)');
      // Remove personality, study, subjects, compat, tip divs that were dynamically added
      var analysisDiv = document.getElementById('result-analysis');
      if (analysisDiv) {
        var next = analysisDiv.nextElementSibling;
        while (next && next.id !== 'score-distribution-section' && !next.classList.contains('grid') && next.id !== 'direct-link-cta' && !next.classList.contains('flex')) {
          var toRemove = next;
          next = next.nextElementSibling;
          toRemove.remove();
        }
      }
      resultContainer.classList.add('hidden');
      startScreen.classList.remove('hidden');
      quizContainer.classList.add('hidden');
      // Show score distribution section again
      document.getElementById('score-distribution-section').classList.remove('hidden');
      // Hide direct link CTA
      document.getElementById('direct-link-cta').classList.add('hidden');
      // Reset URL
      history.replaceState(null, '', '/iber-type-shindan/');
      startScreen.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // Check for result in URL (new path format or legacy query param)
    const urlParams = new URLSearchParams(window.location.search);
    const resultParam = urlParams.get('result');
    const pathMatch = window.location.pathname.match(/\/iber-type-shindan\/([a-z-]+)\/?$/);
    const detectedType = resultParam || (pathMatch && pathMatch[1]);
    if (detectedType && typeDetails[detectedType]) {
      // Direct link - show result immediately
      showResult(detectedType);
    }

    // Back button
    document.getElementById('back-btn').addEventListener('click', () => {
      if (currentQuestion > 0 && answerHistory.length > 0) {
        const lastEntry = answerHistory.pop();
        lastEntry.types.forEach((id) => (scores[id] = Math.max(0, (scores[id] || 0) - 1)));
        lastEntry.subTypes.forEach((id) => (scores[id] = Math.max(0, (scores[id] || 0) - 0.5)));
        currentQuestion--;
        renderQuestion();
      }
    });

    startBtn.addEventListener('click', () => {
      // GA4: 診断開始イベント
      if (typeof window.trackEvent === 'function') {
        window.trackEvent('shindan_start', {
          event_category: 'engagement',
          event_label: 'iber_type_shindan',
          location: 'iber_type_shindan',
        });
      }
      startScreen.classList.add('hidden');
      quizContainer.classList.remove('hidden');
      renderQuestion();
    });

    // Direct start button (shown in direct link results)
    const directStartBtn = document.getElementById('direct-start-btn');
    if (directStartBtn) {
      directStartBtn.addEventListener('click', () => {
        // GA4: 診断開始（直接リンク経由）
        if (typeof window.trackEvent === 'function') {
          window.trackEvent('shindan_start', {
            event_category: 'engagement',
            event_label: 'iber_type_shindan',
            location: 'iber_type_shindan_direct',
          });
        }
        resetQuiz();
        startScreen.classList.add('hidden');
        quizContainer.classList.remove('hidden');
        renderQuestion();
      });
    }

    retryBtn.addEventListener('click', resetQuiz);
  </script>

  <style>
    @keyframes float {
      0%, 100% { transform: translateY(0); }
      50% { transform: translateY(-6px); }
    }
    .shindan-characters > div:nth-child(even) {
      margin-top: 12px;
    }
  </style>
</BaseLayout>
