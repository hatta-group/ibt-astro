        'open-minded': { title: '多角的な視点を活かそう', desc: '柔軟な思考力を持つあなたに、TOKやEEで高評価を狙う指導をします。' },
        'caring': { title: 'チームワーク力を活かそう', desc: 'CASやグループプロジェクトで輝くあなたに、個人課題でも力を発揮する方法を教えます。' },
        'risk-taker': { title: 'チャレンジ精神を結果に', desc: '新しいことに飛び込めるあなたに、挑戦を着実な成果に変える学習法をご提案します。' },
