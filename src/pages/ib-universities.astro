  <!-- JavaScript for tabs and filters -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      // Japan score filter
      const jpFilterBtns = document.querySelectorAll('.jp-filter-btn');
      const jpCards = document.querySelectorAll('.jp-uni-card');

      jpFilterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const filter = (btn as HTMLElement).dataset.jpFilter;

          // Update active state
          jpFilterBtns.forEach(b => {
            b.classList.remove('bg-ibt-red', 'text-white', 'border-ibt-red');
            b.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
          });
          btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');
          btn.classList.add('bg-ibt-red', 'text-white', 'border-ibt-red');

          // Filter cards
          jpCards.forEach(card => {
            const el = card as HTMLElement;
            if (filter === 'all') {
              el.classList.remove('hidden');
              return;
            }

            const scoreText = el.dataset.score || '';
            const nums = scoreText.match(/\d+/g);
            if (!nums || nums.length === 0) {
              el.classList.add('hidden');
              return;
            }

            const minScore = parseInt(nums[0], 10);
            const [filterMin, filterMax] = (filter || '').split('-').map(Number);

            if (minScore >= filterMin && minScore <= filterMax) {
              el.classList.remove('hidden');
            } else {
              el.classList.add('hidden');
            }
          });
        });
      });

      // Overseas region tabs
      const regionTabBtns = document.querySelectorAll('.region-tab-btn');
      const regionPanels = document.querySelectorAll('.region-panel');

      regionTabBtns.forEach(btn => {
        btn.addEventListener('click', () => {
          const region = (btn as HTMLElement).dataset.regionTab;

          // Update active state
          regionTabBtns.forEach(b => {
            b.setAttribute('aria-selected', 'false');
            b.classList.remove('bg-ibt-red', 'text-white', 'border-ibt-red');
            b.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
          });
          btn.setAttribute('aria-selected', 'true');
          btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-200');
          btn.classList.add('bg-ibt-red', 'text-white', 'border-ibt-red');

          // Show/hide panels
          regionPanels.forEach(panel => {
            const el = panel as HTMLElement;
            if (el.id === `region-panel-${region}`) {
              el.classList.remove('hidden');
            } else {
              el.classList.add('hidden');
            }
          });
        });
      });
    });
  </script>
