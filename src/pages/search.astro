---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="サイト内検索｜IB専門家庭教師IBT"
  description="IBT（IB Tutors）サイト内をキーワードで検索できます。ブログ記事、IB校情報、授業内容などを素早く見つけられます。"
  noindex={true}
>
  <Fragment slot="head">
    <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "ホーム", "item": "https://ib-tutors.net/" },
        { "@type": "ListItem", "position": 2, "name": "サイト内検索", "item": "https://ib-tutors.net/search/" }
      ]
    })} />
    <style>
      /* Pagefind UIのカスタマイズ（IBTブランドカラーに合わせる） */
      :root {
        --pagefind-ui-scale: 1;
        --pagefind-ui-primary: #CC2210;
        --pagefind-ui-text: #111111;
        --pagefind-ui-background: #FFFFFF;
        --pagefind-ui-border: #E0E0E0;
        --pagefind-ui-tag: #FFF5F4;
        --pagefind-ui-border-width: 2px;
        --pagefind-ui-border-radius: 12px;
        --pagefind-ui-image-border-radius: 8px;
        --pagefind-ui-image-box-ratio: 16 / 9;
        --pagefind-ui-font: 'Noto Sans JP', 'Zen Kaku Gothic New', sans-serif;
      }

      /* 検索入力欄 */
      .pagefind-ui .pagefind-ui__search-input {
        font-size: 1rem;
        padding: 0.875rem 1rem;
        border-radius: 12px;
        border: 2px solid #E0E0E0;
        transition: border-color 0.2s;
      }
      .pagefind-ui .pagefind-ui__search-input:focus {
        border-color: #CC2210;
        box-shadow: 0 0 0 3px rgba(204, 34, 16, 0.1);
        outline: none;
      }

      /* 検索ボタン */
      .pagefind-ui .pagefind-ui__search-clear {
        color: #CC2210;
      }

      /* 検索結果リンク */
      .pagefind-ui .pagefind-ui__result-link {
        color: #CC2210;
        font-weight: 700;
        text-decoration: none;
        transition: color 0.2s;
      }
      .pagefind-ui .pagefind-ui__result-link:hover {
        color: #A01B0D;
        text-decoration: underline;
      }

      /* 検索結果のハイライト */
      .pagefind-ui mark {
        background-color: #FFF5F4;
        color: #CC2210;
        padding: 0.1em 0.2em;
        border-radius: 2px;
      }

      /* もっと見るボタン */
      .pagefind-ui .pagefind-ui__button {
        background-color: #CC2210;
        color: white;
        border: none;
        border-radius: 9999px;
        padding: 0.75rem 2rem;
        font-weight: 700;
        cursor: pointer;
        transition: background-color 0.2s;
      }
      .pagefind-ui .pagefind-ui__button:hover {
        background-color: #A01B0D;
      }

      /* メッセージテキスト */
      .pagefind-ui .pagefind-ui__message {
        color: #555555;
        font-size: 0.875rem;
      }
    </style>
  </Fragment>

  <!-- Page Hero -->
  <section class="bg-gradient-to-r from-ibt-gradient-start via-ibt-gradient-mid to-ibt-gradient-end py-16 md:py-20">
    <div class="max-w-7xl mx-auto px-4">
      <nav class="text-white/85 text-sm mb-4">
        <a href="/" class="hover:text-white transition-colors">ホーム</a>
        <span class="mx-2">&gt;</span>
        <span class="text-white">サイト内検索</span>
      </nav>
      <h1 class="text-3xl md:text-5xl font-bold text-white">サイト内検索</h1>
      <p class="text-white/80 mt-3 text-lg">キーワードでIBTサイト内の記事やページを検索</p>
    </div>
  </section>

  <!-- Search Section -->
  <section class="py-12 md:py-20 bg-white" data-pagefind-ignore>
    <div class="max-w-3xl mx-auto px-4">
      <div id="search" class="pagefind-ui-wrapper"></div>

      <!-- 検索のヒント -->
      <div class="mt-10 p-6 bg-ibt-bg rounded-2xl border border-ibt-border">
        <h2 class="text-lg font-bold text-ibt-text mb-3">検索のヒント</h2>
        <ul class="space-y-2 text-sm text-ibt-text-light">
          <li class="flex items-start gap-2">
            <span class="text-ibt-red mt-0.5">&#9679;</span>
            <span>「TOK エッセイ」「EE テーマ」などキーワードを入力してください</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-ibt-red mt-0.5">&#9679;</span>
            <span>科目名（数学、物理、日本語A等）で授業関連の記事が見つかります</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="text-ibt-red mt-0.5">&#9679;</span>
            <span>学校名で対応するIB校のページが見つかります</span>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', function() {
      new PagefindUI({
        element: "#search",
        showSubResults: true,
        showImages: false,
        translations: {
          placeholder: "検索キーワードを入力...",
          zero_results: "「[SEARCH_TERM]」に一致する結果が見つかりませんでした",
          many_results: "[COUNT]件の検索結果",
          one_result: "1件の検索結果",
          alt_search: "「[SEARCH_TERM]」の結果がありません。「[DIFFERENT_TERM]」で検索してみましょう",
          search_suggestion: "「[SEARCH_TERM]」の結果がありません。以下のキーワードを試してみてください:",
          searching: "検索中...",
          load_more: "もっと見る"
        }
      });

      // URLパラメータから検索クエリを取得して自動検索
      var params = new URLSearchParams(window.location.search);
      var query = params.get('q');
      if (query) {
        var input = document.querySelector('.pagefind-ui__search-input');
        if (input) {
          input.value = query;
          input.dispatchEvent(new Event('input', { bubbles: true }));
        }
      }
    });
  </script>
</BaseLayout>
